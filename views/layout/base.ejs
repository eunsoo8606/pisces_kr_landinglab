<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>
        <%= title %>
    </title>

    <!-- Favicon 설정 -->
    <link rel="shortcut icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/favicon.png" type="image/png">

    <!-- Open Graph (카카오톡, SNS 공유용 메타 태그) -->
    <meta property="og:type" content="website">
    <meta property="og:title" content="물고기자리 | 프리미엄 숙성회">
    <meta property="og:description" content="칼 없는 주방, 주방장 없는 횟집. 물고기자리에서 성공적인 프랜차이즈 창업을 시작하세요.">
    <meta property="og:image" content="<%= baseUrl %>/images/logo/meta-logo.png">
    <meta property="og:url" content="<%= baseUrl %>">

    <link rel="stylesheet" href="/css/style.css?v=5.1">
    <!-- GSAP for animations -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/ScrollTrigger.min.js"></script>
    <!-- Lenis for smooth scrolling -->
    <script src="https://unpkg.com/@studio-freight/lenis@1.0.33/dist/lenis.min.js"></script>
</head>

