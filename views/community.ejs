<%- include('layout/base', { title: '커뮤니티 | 물고기자리 - 프리미엄 숙성회', branding: 'PISCES since 2002' }) %>

    <!-- 커뮤니티 페이지 히어로 영역 (프리미엄 비디오 배경) -->
    <section class="comm-page-hero">
        <div class="comm-hero-video-bg">
            <video autoplay loop muted playsinline>
                <source src="/video/main.mp4" type="video/mp4">
            </video>
            <div class="comm-hero-overlay"></div>
        </div>
        <div class="container comm-hero-container">
            <span class="comm-hero-tag">COMMUNITY</span>
            <h1 class="comm-hero-title">물고기자리 소통 공간</h1>
            <p class="comm-hero-desc">물고기자리의 새로운 소식과 자주 묻는 질문, 고객의 소중한 의견을 나누는 공간입니다.</p>
        </div>
    </section>

    <!-- 커뮤니티 컨텐츠 섹션 -->
    <section class="section-comm comm-page-content">
        <div class="comm-inner">

            <!-- 탭 메뉴 영역 (EJS activeTab 변수 바인딩) -->
            <div class="comm-header-wrap">
                <nav class="comm-tabs" id="commTabs">
                    <button class="comm-tab-btn <%= activeTab === 'notice' ? 'active' : '' %>" data-tab="notice">공지사항</button>
                    <button class="comm-tab-btn <%= activeTab === 'faq' ? 'active' : '' %>" data-tab="faq">자주 묻는 질문 (FAQ)</button>
                    <button class="comm-tab-btn <%= activeTab === 'voice' ? 'active' : '' %>" data-tab="voice">고객의 소리</button>
                    <button class="comm-tab-btn <%= activeTab === 'inquiry' ? 'active' : '' %>" data-tab="inquiry">문의게시판</button>
                </nav>
            </div>

            <!-- 탭 패널 영역 -->
            <div class="comm-showcase">

                <!-- 1. 공지사항 (Notice) -->
                <div class="comm-panel <%= activeTab === 'notice' ? 'active' : '' %>" data-panel="notice">
                    <div class="board-table-wrap">
                        <table class="board-table">
                            <thead>
                                <tr>
                                    <th class="col-num" style="width: 80px;">번호</th>
                                    <th class="col-subject">제목</th>
                                    <th class="col-date" style="width: 130px;">작성일</th>
                                    <th class="col-views" style="width: 90px;">조회수</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (activeTab === 'notice' && list && list.length > 0) { %>
                                    <% list.forEach((item, index) => { %>
                                        <tr class="<%= item.is_pinned === 1 ? 'notice-pinned' : '' %>">
                                            <td class="col-num">
                                                <% if (item.is_pinned === 1) { %>
                                                    <span class="badge-pin">필독</span>
                                                <% } else { %>
                                                    <%= list.length - index %>
                                                <% } %>
                                            </td>
                                            <td class="col-subject" style="text-align: left;">
                                                <a href="javascript:void(0);" class="notice-title-link" onclick="toggleNoticeContent('<%= item.id %>')">
                                                    <%= item.title %>
                                                </a>
                                                <div class="notice-content-fold" id="notice-content-<%= item.id %>" style="display: none; padding: 20px; background: rgba(255,255,255,0.02); margin-top: 15px; border-radius: 10px; border: 1.5px solid rgba(0, 242, 254, 0.1); color: rgba(255,255,255,0.85); line-height: 1.7; text-align: left; font-size: 14px; box-shadow: inset 0 0 15px rgba(0,242,254,0.03);"><%- item.content %></div>
                                            </td>
                                            <td class="col-date"><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                            <td class="col-views"><%= item.views %></td>
                                        </tr>
                                    <% }) %>
                                <% } else if (activeTab === 'notice') { %>
                                    <tr>
                                        <td colspan="4" style="text-align: center; padding: 50px; color: rgba(255,255,255,0.4);">등록된 공지사항이 존재하지 않습니다.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>
                </div>

                <!-- 2. 자주 묻는 질문 (FAQ) -->
                <div class="comm-panel <%= activeTab === 'faq' ? 'active' : '' %>" data-panel="faq">
                    <div class="faq-accordion-wrap">
                        <% if (activeTab === 'faq' && list && list.length > 0) { %>
                            <% list.forEach(item => { %>
                                <div class="faq-item">
                                    <button class="faq-question">
                                        <span class="faq-icon-q">Q</span>
                                        <span class="faq-q-text"><%= item.title %></span>
                                        <span class="faq-arrow-icon">&plus;</span>
                                    </button>
                                    <div class="faq-answer">
                                        <div class="faq-answer-inner"><%- item.content %></div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else if (activeTab === 'faq') { %>
                            <div style="text-align: center; padding: 50px; color: rgba(255,255,255,0.4);">등록된 자주 묻는 질문이 존재하지 않습니다.</div>
                        <% } %>
                    </div>
                </div>

                <!-- 3. 고객의 소리 (Voice) -->
                <div class="comm-panel <%= activeTab === 'voice' ? 'active' : '' %>" data-panel="voice">
                    <!-- 고객의 소리 비밀글 리스트 -->
                    <div class="comm-list-wrap">
                        <div class="comm-list-header">
                            <h4 class="comm-list-title">불편/불만 접수 현황</h4>
                            <button type="button" class="btn-open-voice-modal" id="btnOpenVoiceModal">
                                <span>불편/불만 접수하기</span>
                                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                            </button>
                        </div>
                        <div class="board-table-wrap">
                            <table class="board-table">
                                <thead>
                                    <tr>
                                        <th class="col-num">번호</th>
                                        <th class="col-subject">제목</th>
                                        <th class="col-author">작성자</th>
                                        <th class="col-date">등록일</th>
                                        <th class="col-status">처리상태</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (activeTab === 'voice' && list && list.length > 0) { %>
                                        <% list.forEach((item, index) => { %>
                                            <% 
                                                let maskedName = '익명';
                                                if (item.author_name) {
                                                    const len = item.author_name.length;
                                                    if (len === 2) {
                                                        maskedName = item.author_name[0] + '*';
                                                    } else if (len > 2) {
                                                        maskedName = item.author_name[0] + '*'.repeat(len - 2) + item.author_name[len - 1];
                                                    } else {
                                                        maskedName = item.author_name;
                                                    }
                                                }
                                            %>
                                            <tr>
                                                <td class="col-num"><%= list.length - index %></td>
                                                <td class="col-subject private-post">
                                                    <svg class="icon-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                                    </svg>
                                                    <span>비밀글입니다.</span>
                                                </td>
                                                <td class="col-author"><%= maskedName %></td>
                                                <td class="col-date"><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                                <td class="col-status">
                                                    <span class="badge-status <%= item.status === 'complete' ? 'status-complete' : 'status-pending' %>">
                                                        <%= item.status === 'complete' ? '답변완료' : '접수완료' %>
                                                    </span>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else if (activeTab === 'voice') { %>
                                        <tr>
                                            <td colspan="5" style="text-align: center; padding: 50px; color: rgba(255,255,255,0.4);">접수된 고객의 소리가 존재하지 않습니다.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <!-- 4. 문의게시판 (Inquiry) -->
                <div class="comm-panel <%= activeTab === 'inquiry' ? 'active' : '' %>" data-panel="inquiry">
                    <!-- 문의 비밀글 리스트 -->
                    <div class="comm-list-wrap">
                        <div class="comm-list-header">
                            <h4 class="comm-list-title">가맹/비즈니스 문의 현황</h4>
                            <button type="button" class="btn-open-voice-modal" id="btnOpenInquiryModal">
                                <span>문의 접수하기</span>
                                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                            </button>
                        </div>
                        <div class="board-table-wrap">
                            <table class="board-table">
                                <thead>
                                    <tr>
                                        <th class="col-num">번호</th>
                                        <th class="col-subject">제목</th>
                                        <th class="col-author">작성자</th>
                                        <th class="col-date">등록일</th>
                                        <th class="col-status">처리상태</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (activeTab === 'inquiry' && list && list.length > 0) { %>
                                        <% list.forEach((item, index) => { %>
                                            <% 
                                                let maskedName = '익명';
                                                if (item.author_name) {
                                                    const len = item.author_name.length;
                                                    if (len === 2) {
                                                        maskedName = item.author_name[0] + '*';
                                                    } else if (len > 2) {
                                                        maskedName = item.author_name[0] + '*'.repeat(len - 2) + item.author_name[len - 1];
                                                    } else {
                                                        maskedName = item.author_name;
                                                    }
                                                }
                                            %>
                                            <tr>
                                                <td class="col-num"><%= list.length - index %></td>
                                                <td class="col-subject private-post">
                                                    <svg class="icon-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                                    </svg>
                                                    <span>비밀글입니다.</span>
                                                </td>
                                                <td class="col-author"><%= maskedName %></td>
                                                <td class="col-date"><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                                <td class="col-status">
                                                    <span class="badge-status <%= item.status === 'complete' ? 'status-complete' : 'status-pending' %>">
                                                        <%= item.status === 'complete' ? '답변완료' : '답변대기' %>
                                                    </span>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else if (activeTab === 'inquiry') { %>
                                        <tr>
                                            <td colspan="5" style="text-align: center; padding: 50px; color: rgba(255,255,255,0.4);">접수된 가맹 및 제휴 문의가 존재하지 않습니다.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </section>

    <!-- 고객의 소리 접수 모달 팝업 -->
    <div class="comm-modal-wrap" id="commVoiceModal">
        <div class="comm-modal-overlay" id="commVoiceModalOverlay"></div>
        <div class="comm-modal-content">
            <button type="button" class="comm-modal-close" id="btnCloseVoiceModal" aria-label="닫기">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <div class="inquiry-intro">
                <h3 class="box-title">고객 불편/불만 접수</h3>
                <p class="box-desc">물고기자리 매장을 이용하시면서 겪으신 불편이나 불만 사항을 남겨주시면 대표가 직접 확인하고 신속히 개선하겠습니다. 모든 내용은 비밀글로 안전하게 접수됩니다.</p>
            </div>
            <form class="comm-inquiry-form" id="commVoiceForm">
                <div class="form-row">
                    <div class="form-col">
                        <label for="commVoiceName" class="form-label">작성자 성함 <span class="required-dot"></span></label>
                        <input type="text" id="commVoiceName" class="form-control" placeholder="성함을 입력하세요." required>
                    </div>
                    <div class="form-col">
                        <label for="commVoicePhone" class="form-label">연락처 <span class="required-dot"></span></label>
                        <input type="tel" id="commVoicePhone" class="form-control" placeholder="연락처를 입력하세요." required>
                    </div>
                </div>

                <div class="form-group-full">
                    <label for="commVoiceContent" class="form-label">불편/불만 사항 <span class="required-dot"></span></label>
                    <textarea id="commVoiceContent" class="form-control text-area" placeholder="불편을 겪으신 구체적인 내용을 작성해 주세요. (비밀글로 접수됩니다)" required></textarea>
                </div>

                <div class="form-agreement-wrap">
                    <label class="agreement-label">
                        <input type="checkbox" id="commVoicePrivacyAgree" checked required>
                        <span class="checkbox-box"></span>
                        <span class="agreement-text">개인정보 수집 및 이용약관에 동의합니다.</span>
                    </label>
                </div>

                <div class="form-btn-submit-wrap">
                    <button type="submit" class="btn-comm-submit">
                        <span>불편/불만 접수하기 (비밀글)</span>
                        <svg class="submit-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- 가맹 및 제휴 문의 접수 모달 팝업 -->
    <div class="comm-modal-wrap" id="commInquiryModal">
        <div class="comm-modal-overlay" id="commInquiryModalOverlay"></div>
        <div class="comm-modal-content">
            <button type="button" class="comm-modal-close" id="btnCloseInquiryModal" aria-label="닫기">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <div class="inquiry-intro">
                <h3 class="box-title">가맹 및 제휴 문의</h3>
                <p class="box-desc">물고기자리 성공 창업을 위한 가맹 상담, 개설 문의, 비즈니스 제휴 제안을 남겨주시면 가맹본부 담당자가 신속히 확인하여 답변을 드리겠습니다.</p>
            </div>
            
            <form class="comm-inquiry-form" id="commInquiryForm">
                <div class="form-row">
                    <div class="form-col">
                        <label for="commInquirerName" class="form-label">작성자 성함 <span class="required-dot"></span></label>
                        <input type="text" id="commInquirerName" class="form-control" placeholder="성함을 입력하세요." required>
                    </div>
                    <div class="form-col">
                        <label for="commInquirerPhone" class="form-label">연락처 <span class="required-dot"></span></label>
                        <input type="tel" id="commInquirerPhone" class="form-control" placeholder="연락처를 입력하세요." required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-col">
                        <label for="commInquiryType" class="form-label">문의 분류 <span class="required-dot"></span></label>
                        <select id="commInquiryType" class="form-control select-control" required>
                            <option value="franchise">신규 가맹 / 창업 상담 문의</option>
                            <option value="location">매장 개설 / 상권 분석 문의</option>
                            <option value="alliance">비즈니스 제휴 / 납품 문의</option>
                            <option value="other">기타 문의사항</option>
                        </select>
                    </div>
                    <div class="form-col">
                        <label for="commInquirerEmail" class="form-label">이메일 주소</label>
                        <input type="email" id="commInquirerEmail" class="form-control" placeholder="이메일(선택)을 입력하세요.">
                    </div>
                </div>

                <div class="form-group-full">
                    <label for="commInquiryContent" class="form-label">문의 내용 <span class="required-dot"></span></label>
                    <textarea id="commInquiryContent" class="form-control text-area" placeholder="문의하실 구체적인 내용을 작성해 주세요." required></textarea>
                </div>

                <div class="form-agreement-wrap">
                    <label class="agreement-label">
                        <input type="checkbox" id="commPrivacyAgree" checked required>
                        <span class="checkbox-box"></span>
                        <span class="agreement-text">개인정보 수집 및 이용약관에 동의합니다.</span>
                    </label>
                </div>

                <div class="form-btn-submit-wrap">
                    <button type="submit" class="btn-comm-submit">
                        <span>문의 접수하기 (비밀글)</span>
                        <svg class="submit-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Scroll to Top Button -->
    <button type="button" id="btnScrollTop" class="btn-scroll-top" aria-label="맨 위로 스크롤">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
    </button>

    <script>
        // 1. 탭 버튼 클릭 이벤트 (SSR 페이지 이동 처리)
        const tabButtons = document.querySelectorAll('.comm-tab-btn');
        tabButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                const targetTab = btn.dataset.tab;
                location.href = `/community/${targetTab}`;
            });
        });

        // 2. 공지사항 상세 내용 접기/펴기 토글 기능
        function toggleNoticeContent(id) {
            const contentBox = document.getElementById(`notice-content-${id}`);
            if (contentBox) {
                if (contentBox.style.display === 'none') {
                    // 열 때 다른 모든 열려있는 공지 접기
                    document.querySelectorAll('.notice-content-fold').forEach(box => {
                        box.style.display = 'none';
                    });
                    contentBox.style.display = 'block';
                } else {
                    contentBox.style.display = 'none';
                }
            }
        }

        // 3. FAQ 아코디언 토글 기능
        const faqQuestions = document.querySelectorAll('.faq-question');
        faqQuestions.forEach(q => {
            q.addEventListener('click', () => {
                const item = q.parentElement;
                const answer = q.nextElementSibling;
                const icon = q.querySelector('.faq-arrow-icon');
                
                const isOpen = item.classList.contains('active');
                
                // 모든 FAQ 닫기
                document.querySelectorAll('.faq-item').forEach(el => {
                    el.classList.remove('active');
                    el.querySelector('.faq-answer').style.maxHeight = null;
                    el.querySelector('.faq-arrow-icon').innerHTML = '&plus;';
                });
                
                if (!isOpen) {
                    item.classList.add('active');
                    answer.style.maxHeight = answer.scrollHeight + 'px';
                    icon.innerHTML = '&minus;';
                }
            });
        });

        // 4. 모달 열기/닫기 처리
        const setupModal = (btnOpenId, modalId, btnCloseId, overlayId) => {
            const btnOpen = document.getElementById(btnOpenId);
            const modal = document.getElementById(modalId);
            const btnClose = document.getElementById(btnCloseId);
            const overlay = document.getElementById(overlayId);

            if (btnOpen && modal && btnClose && overlay) {
                const openModal = () => modal.classList.add('active');
                const closeModal = () => modal.classList.remove('active');

                btnOpen.addEventListener('click', openModal);
                btnClose.addEventListener('click', closeModal);
                overlay.addEventListener('click', closeModal);
            }
        };

        setupModal('btnOpenVoiceModal', 'commVoiceModal', 'btnCloseVoiceModal', 'commVoiceModalOverlay');
        setupModal('btnOpenInquiryModal', 'commInquiryModal', 'btnCloseInquiryModal', 'commInquiryModalOverlay');

        // 5. 고객의 소리 (Voice) 비동기 접수 처리
        const voiceForm = document.getElementById('commVoiceForm');
        if (voiceForm) {
            voiceForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                const name = document.getElementById('commVoiceName').value;
                const phone = document.getElementById('commVoicePhone').value;
                const content = document.getElementById('commVoiceContent').value;
                const privacyAgree = document.getElementById('commVoicePrivacyAgree').checked;

                if (!privacyAgree) {
                    alert('개인정보 수집 및 이용약관에 동의하셔야 접수가 가능합니다.');
                    return;
                }

                try {
                    const response = await fetch('/api/community/voice', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ name, phone, content })
                    });

                    const data = await response.json();
                    if (data.success) {
                        alert(data.message || '성공적으로 접수되었습니다.');
                        location.reload(); // 새로고침해서 리스트 갱신
                    } else {
                        alert(data.message || '접수에 실패했습니다.');
                    }
                } catch (err) {
                    console.error('Submit voice error:', err);
                    alert('네트워크 오류로 접수에 실패했습니다.');
                }
            });
        }

        // 6. 가맹 및 제휴 문의 (Inquiry) 비동기 접수 처리
        const inquiryForm = document.getElementById('commInquiryForm');
        if (inquiryForm) {
            inquiryForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                const name = document.getElementById('commInquirerName').value;
                const phone = document.getElementById('commInquirerPhone').value;
                const type = document.getElementById('commInquiryType').value;
                const email = document.getElementById('commInquirerEmail').value;
                const content = document.getElementById('commInquiryContent').value;
                const privacyAgree = document.getElementById('commPrivacyAgree').checked;

                if (!privacyAgree) {
                    alert('개인정보 수집 및 이용약관에 동의하셔야 접수가 가능합니다.');
                    return;
                }

                try {
                    const response = await fetch('/api/community/inquiry', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ name, phone, email, type, content })
                    });

                    const data = await response.json();
                    if (data.success) {
                        alert(data.message || '성공적으로 문의가 접수되었습니다.');
                        location.reload(); // 새로고침해서 리스트 갱신
                    } else {
                        alert(data.message || '문의 접수에 실패했습니다.');
                    }
                } catch (err) {
                    console.error('Submit inquiry error:', err);
                    alert('네트워크 오류로 접수에 실패했습니다.');
                }
            });
        }
    </script>

