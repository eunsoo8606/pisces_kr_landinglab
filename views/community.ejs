<%- include('layout/base', { title: '커뮤니티 | 물고기자리 - 프리미엄 숙성회', branding: 'PISCES since 2002' }) %>

    <style>
        /* 데스크톱 모바일 컨트롤 숨김 */
        .mobile-comm-controls {
            display: none;
        }

        /* 사용자 커뮤니티 모바일 최적화 스타일 */
        @media (max-width: 768px) {
            /* 1. 히어로 및 메인 레이아웃 튜닝 (헤더 가림 현상 해결을 위해 padding-top 증대) */
            .comm-page-hero {
                padding-top: 135px !important;
                padding-bottom: 45px !important;
                min-height: auto !important;
            }
            .comm-hero-title {
                font-size: 28px !important;
                word-break: keep-all;
            }
            .comm-hero-desc {
                font-size: 13px !important;
                word-break: keep-all;
                line-height: 1.6;
            }
            .section-comm {
                padding: 30px 15px !important;
            }

            /* 2. 탭 가로 버튼 숨김 및 모바일 컨트롤 활성화 */
            .comm-tabs {
                display: none !important;
            }
            
            .mobile-comm-controls {
                display: flex;
                flex-direction: column;
                gap: 12px;
                width: 100%;
                margin-top: 5px;
                margin-bottom: 25px;
                box-sizing: border-box;
            }
            /* 모바일 전용 2x2 격자형 탭 버튼 스타일 */
            .comm-mobile-grid-tabs {
                display: grid !important;
                grid-template-columns: 1fr 1fr !important;
                gap: 8px !important;
                width: 100% !important;
                box-sizing: border-box !important;
                margin-bottom: 4px !important;
            }

            .comm-mobile-grid-btn {
                padding: 12px 10px !important;
                font-size: 13.5px !important;
                font-weight: 700 !important;
                color: rgba(255, 255, 255, 0.7) !important;
                background: rgba(255, 255, 255, 0.02) !important;
                border: 1px solid rgba(255, 255, 255, 0.08) !important;
                border-radius: 10px !important;
                text-align: center !important;
                cursor: pointer !important;
                transition: all 0.2s ease !important;
                box-sizing: border-box !important;
                outline: none !important;
            }

            .comm-mobile-grid-btn.active {
                background: linear-gradient(135deg, #314e8d 0%, #0056b3 100%) !important;
                border-color: transparent !important;
                color: #ffffff !important;
                box-shadow: 0 4px 15px rgba(49, 78, 141, 0.35) !important;
            }

            .mobile-search-wrap {
                width: 100%;
                display: flex;
                position: relative;
                box-sizing: border-box;
            }
            
            .comm-mobile-search {
                width: 100%;
                padding: 13px 50px 13px 18px;
                font-size: 14px;
                color: #ffffff;
                background: rgba(255, 255, 255, 0.02);
                border: 1px solid rgba(255, 255, 255, 0.08);
                border-radius: 12px;
                outline: none;
                box-sizing: border-box;
                transition: all 0.25s ease;
            }
            
            .comm-mobile-search:focus {
                border-color: rgba(49, 78, 141, 0.6);
                background-color: rgba(255, 255, 255, 0.05);
                box-shadow: 0 0 10px rgba(49, 78, 141, 0.15);
            }
            
            .btn-comm-search {
                position: absolute;
                right: 4px;
                top: 50%;
                transform: translateY(-50%);
                background: none;
                border: none;
                color: rgba(74, 108, 179, 0.8);
                cursor: pointer;
                padding: 10px 14px;
                display: flex;
                align-items: center;
                justify-content: center;
                transition: color 0.2s ease;
            }
            
            .btn-comm-search svg {
                width: 20px;
                height: 20px;
            }
            
            .btn-comm-search:hover {
                color: #00a8cc;
            }

            /* 3. 모바일 전용 독립 디브 카드 목록 레이아웃 (테이블 가로 뚫림/비대칭 완전 예방) */
            .desktop-only-table {
                display: block;
            }
            .mobile-board-card-list {
                display: none;
            }

            .desktop-only-table {
                display: none !important;
            }
            .mobile-board-card-list {
                display: flex !important;
                flex-direction: column;
                gap: 12px;
                width: 100% !important;
                box-sizing: border-box !important;
                padding: 0 15px !important; /* 좌우 15px 패딩 균형 피팅 */
                margin: 0 !important;
            }
            
            .mobile-comm-card {
                background: rgba(255, 255, 255, 0.02) !important;
                border: 1.5px solid rgba(255, 255, 255, 0.04) !important;
                border-radius: 14px !important;
                padding: 16px 15px !important;
                box-sizing: border-box !important;
                width: 100% !important;
                display: flex !important;
                flex-direction: column;
                gap: 8px;
                position: relative !important;
                transition: transform 0.2s ease, background 0.2s ease;
                margin-left: 0 !important;
                margin-right: 0 !important;
            }
            
            .mobile-comm-card:hover {
                background: rgba(255, 255, 255, 0.04) !important;
            }
            
            /* 필독 공지 카드 강조 */
            .mobile-comm-card.notice-pinned {
                border: 1.5px solid rgba(49, 78, 141, 0.4) !important;
                background: rgba(49, 78, 141, 0.04) !important;
            }
            
            .mobile-comm-card.notice-pinned:hover {
                background: rgba(49, 78, 141, 0.08) !important;
            }
            
            .card-meta-top {
                display: flex !important;
                align-items: center !important;
                gap: 8px !important;
            }
            
            .card-num-badge {
                font-size: 11px !important;
                font-weight: 800 !important;
                color: rgba(74, 108, 179, 0.9) !important;
            }
            
            .badge-pin {
                background: linear-gradient(135deg, #ef4444 0%, #ff7878 100%) !important;
                color: #ffffff !important;
                padding: 2px 6px !important;
                border-radius: 4px !important;
                font-size: 10px !important;
                font-weight: bold !important;
            }
            
            .card-title {
                margin: 0 !important;
                font-size: 15px !important;
                font-weight: 700 !important;
                color: #ffffff !important;
                line-height: 1.4 !important;
                text-align: left !important;
                word-break: break-all !important;
            }
            
            .card-title a {
                color: inherit !important;
                text-decoration: none !important;
            }
            
            .card-meta-bottom {
                display: flex !important;
                align-items: center !important;
                gap: 10px !important;
                font-size: 11.5px !important;
                color: rgba(255, 255, 255, 0.4) !important;
                margin-top: 2px !important;
            }
            
            .meta-separator {
                color: rgba(255, 255, 255, 0.15) !important;
            }
            
            .card-status-wrap {
                position: absolute !important;
                right: 15px !important;
                top: 16px !important;
            }
            
            .badge-status {
                padding: 3px 8px !important;
                font-size: 10.5px !important;
                border-radius: 6px !important;
            }
            
            .no-data-msg {
                text-align: center !important;
                padding: 40px 15px !important;
                color: rgba(255, 255, 255, 0.4) !important;
                font-size: 14px !important;
            }

            /* 공지사항 본문 접기 스타일 */
            .notice-content-fold {
                padding: 15px !important;
                margin-top: 12px !important;
                font-size: 13.5px !important;
                word-break: break-all !important;
                text-align: left !important;
            }

            /* 4. 접수 영역 헤더 및 모달 최적화 */
            .comm-list-header {
                flex-direction: column !important;
                align-items: stretch !important;
                gap: 12px !important;
                margin-bottom: 20px !important;
            }
            .comm-list-title {
                text-align: center !important;
                font-size: 18px !important;
            }
            .btn-open-voice-modal {
                width: 100% !important;
                justify-content: center !important;
                padding: 12px 20px !important;
                font-size: 13.5px !important;
                box-sizing: border-box !important;
            }

            /* 모달 팝업 가로폭 뚫림 방지 */
            .comm-modal-content {
                width: calc(100% - 30px) !important;
                max-width: 100% !important;
                padding: 24px 16px !important;
                box-sizing: border-box !important;
                border-radius: 16px !important;
            }
            .inquiry-intro .box-title {
                font-size: 18px !important;
            }
            .inquiry-intro .box-desc {
                font-size: 12px !important;
                line-height: 1.6 !important;
                margin-top: 6px !important;
            }

            .comm-inquiry-form .form-row {
                grid-template-columns: 1fr !important;
                gap: 12px !important;
                margin-bottom: 12px !important;
            }
            .comm-inquiry-form .form-group-full {
                margin-bottom: 16px !important;
            }
            .comm-inquiry-form .form-label {
                font-size: 13px !important;
            }
            .comm-inquiry-form .form-control {
                padding: 10px 14px !important;
                font-size: 13px !important;
                border-radius: 8px !important;
            }
            .comm-inquiry-form .text-area {
                height: 140px !important;
            }
            .form-agreement-wrap {
                margin-bottom: 16px !important;
            }
            .agreement-text {
                font-size: 12px !important;
            }
            .btn-comm-submit {
                width: 100% !important;
                box-sizing: border-box !important;
                padding: 12px 20px !important;
                font-size: 13.5px !important;
                justify-content: center !important;
            }

            /* 가로 스크롤 제거 및 한눈에 들어오는 너비 고정 */
            .comm-showcase,
            .comm-panel {
                width: 100% !important;
                overflow-x: visible !important;
                overflow-y: visible !important;
                box-sizing: border-box !important;
            }
            .faq-accordion-wrap,
            .comm-list-header {
                padding: 0 15px !important;
                box-sizing: border-box !important;
            }
        }
    </style>

    <!-- 커뮤니티 페이지 히어로 영역 (프리미엄 비디오 배경) -->
    <section class="comm-page-hero">
        <div class="comm-hero-video-bg">
            <video autoplay loop muted playsinline>
                <source src="/video/main.mp4" type="video/mp4">
            </video>
            <div class="comm-hero-overlay"></div>
        </div>
        <div class="container comm-hero-container">
            <span class="comm-hero-tag">COMMUNITY</span>
            <h1 class="comm-hero-title">물고기자리 소통 공간</h1>
            <p class="comm-hero-desc">물고기자리의 새로운 소식과 자주 묻는 질문, 고객의 소중한 의견을 나누는 공간입니다.</p>
        </div>
    </section>

    <!-- 커뮤니티 컨텐츠 섹션 -->
    <section class="section-comm comm-page-content">
        <div class="comm-inner">

            <!-- 탭 메뉴 영역 (EJS activeTab 변수 바인딩) -->
            <div class="comm-header-wrap">
                <nav class="comm-tabs" id="commTabs">
                    <button class="comm-tab-btn <%= activeTab === 'notice' ? 'active' : '' %>" data-tab="notice">공지사항</button>
                    <button class="comm-tab-btn <%= activeTab === 'faq' ? 'active' : '' %>" data-tab="faq">자주 묻는 질문 (FAQ)</button>
                    <button class="comm-tab-btn <%= activeTab === 'voice' ? 'active' : '' %>" data-tab="voice">고객의 소리</button>
                    <button class="comm-tab-btn <%= activeTab === 'inquiry' ? 'active' : '' %>" data-tab="inquiry">문의게시판</button>
                </nav>

                <!-- 모바일 전용 게시판 2x2 격자형 타이틀 탭 및 실시간 검색 조건 바 -->
                <div class="mobile-comm-controls">
                    <div class="comm-mobile-grid-tabs">
                        <button type="button" class="comm-mobile-grid-btn <%= activeTab === 'notice' ? 'active' : '' %>" data-tab="notice">공지사항</button>
                        <button type="button" class="comm-mobile-grid-btn <%= activeTab === 'faq' ? 'active' : '' %>" data-tab="faq">자주 묻는 질문 (FAQ)</button>
                        <button type="button" class="comm-mobile-grid-btn <%= activeTab === 'voice' ? 'active' : '' %>" data-tab="voice">고객의 소리</button>
                        <button type="button" class="comm-mobile-grid-btn <%= activeTab === 'inquiry' ? 'active' : '' %>" data-tab="inquiry">문의게시판</button>
                    </div>
                    <div class="mobile-search-wrap">
                        <input type="text" id="commSearchInput" class="comm-mobile-search" placeholder="제목이나 내용으로 검색..." aria-label="게시글 검색">
                        <button type="button" class="btn-comm-search" id="btnCommSearch" aria-label="검색">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                        </button>
                    </div>
                </div>
            </div>

            <!-- 탭 패널 영역 -->
            <div class="comm-showcase">

                <!-- 1. 공지사항 (Notice) -->
                <div class="comm-panel <%= activeTab === 'notice' ? 'active' : '' %>" data-panel="notice">
                    <!-- 데스크톱 전용 테이블 목록 -->
                    <div class="board-table-wrap desktop-only-table">
                        <table class="board-table">
                            <thead>
                                <tr>
                                    <th class="col-num" style="width: 80px;">번호</th>
                                    <th class="col-subject">제목</th>
                                    <th class="col-date" style="width: 130px;">작성일</th>
                                    <th class="col-views" style="width: 90px;">조회수</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% if (activeTab === 'notice' && list && list.length > 0) { %>
                                    <% list.forEach((item, index) => { %>
                                        <tr class="<%= item.is_pinned === 1 ? 'notice-pinned' : '' %>">
                                            <td class="col-num">
                                                <% if (item.is_pinned === 1) { %>
                                                    <span class="badge-pin">필독</span>
                                                <% } else { %>
                                                    <%= list.length - index %>
                                                <% } %>
                                            </td>
                                            <td class="col-subject" style="text-align: left;">
                                                <a href="javascript:void(0);" class="notice-title-link" onclick="toggleNoticeContent('<%= item.id %>')">
                                                    <%= item.title %>
                                                </a>
                                                <div class="notice-content-fold" id="notice-content-<%= item.id %>" style="display: none; padding: 20px; background: rgba(255,255,255,0.02); margin-top: 15px; border-radius: 10px; border: 1.5px solid rgba(49, 78, 141, 0.25); color: rgba(255,255,255,0.85); line-height: 1.7; text-align: left; font-size: 14px; box-shadow: inset 0 0 15px rgba(49, 78, 141, 0.05);"><%- item.content %></div>
                                            </td>
                                            <td class="col-date"><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                            <td class="col-views"><%= item.views %></td>
                                        </tr>
                                    <% }) %>
                                <% } else if (activeTab === 'notice') { %>
                                    <tr>
                                        <td colspan="4" style="text-align: center; padding: 50px; color: rgba(255,255,255,0.4);">등록된 공지사항이 존재하지 않습니다.</td>
                                    </tr>
                                <% } %>
                            </tbody>
                        </table>
                    </div>

                    <!-- 모바일 전용 디브 카드 목록 -->
                    <div class="mobile-board-card-list">
                        <% if (activeTab === 'notice' && list && list.length > 0) { %>
                            <% list.forEach((item, index) => { %>
                                <div class="mobile-comm-card <%= item.is_pinned === 1 ? 'notice-pinned' : '' %>">
                                    <div class="card-meta-top">
                                        <% if (item.is_pinned === 1) { %>
                                            <span class="badge-pin">필독</span>
                                        <% } else { %>
                                            <span class="card-num-badge">No. <%= list.length - index %></span>
                                        <% } %>
                                    </div>
                                    <h4 class="card-title">
                                        <a href="javascript:void(0);" onclick="toggleNoticeContentMobile('<%= item.id %>')">
                                            <%= item.title %>
                                        </a>
                                    </h4>
                                    <div class="card-meta-bottom">
                                        <span class="meta-date"><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></span>
                                        <span class="meta-separator">|</span>
                                        <span class="meta-views">조회 <%= item.views %></span>
                                    </div>
                                    <div class="notice-content-fold" id="notice-content-mobile-<%= item.id %>" style="display: none; padding: 15px; background: rgba(255,255,255,0.02); margin-top: 15px; border-radius: 10px; border: 1.5px solid rgba(49, 78, 141, 0.25); color: rgba(255,255,255,0.85); line-height: 1.7; text-align: left; font-size: 13.5px;"><%- item.content %></div>
                                </div>
                            <% }) %>
                        <% } else if (activeTab === 'notice') { %>
                            <div class="no-data-msg">등록된 공지사항이 존재하지 않습니다.</div>
                        <% } %>
                    </div>
                </div>

                <!-- 2. 자주 묻는 질문 (FAQ) -->
                <div class="comm-panel <%= activeTab === 'faq' ? 'active' : '' %>" data-panel="faq">
                    <div class="faq-accordion-wrap">
                        <% if (activeTab === 'faq' && list && list.length > 0) { %>
                            <% list.forEach(item => { %>
                                <div class="faq-item">
                                    <button class="faq-question">
                                        <span class="faq-icon-q">Q</span>
                                        <span class="faq-q-text"><%= item.title %></span>
                                        <span class="faq-arrow-icon">&plus;</span>
                                    </button>
                                    <div class="faq-answer">
                                        <div class="faq-answer-inner"><%- item.content %></div>
                                    </div>
                                </div>
                            <% }) %>
                        <% } else if (activeTab === 'faq') { %>
                            <div style="text-align: center; padding: 50px; color: rgba(255,255,255,0.4);">등록된 자주 묻는 질문이 존재하지 않습니다.</div>
                        <% } %>
                    </div>
                </div>

                <!-- 3. 고객의 소리 (Voice) -->
                <div class="comm-panel <%= activeTab === 'voice' ? 'active' : '' %>" data-panel="voice">
                    <!-- 고객의 소리 비밀글 리스트 -->
                    <div class="comm-list-wrap">
                        <div class="comm-list-header">
                            <h4 class="comm-list-title">불편/불만 접수 현황</h4>
                            <button type="button" class="btn-open-voice-modal" id="btnOpenVoiceModal">
                                <span>불편/불만 접수하기</span>
                                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                            </button>
                        </div>
                        
                        <!-- 데스크톱용 테이블 목록 -->
                        <div class="board-table-wrap desktop-only-table">
                            <table class="board-table">
                                <thead>
                                    <tr>
                                        <th class="col-num">번호</th>
                                        <th class="col-subject">제목</th>
                                        <th class="col-author">작성자</th>
                                        <th class="col-date">등록일</th>
                                        <th class="col-status">처리상태</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (activeTab === 'voice' && list && list.length > 0) { %>
                                        <% list.forEach((item, index) => { %>
                                            <% 
                                                let maskedName = '익명';
                                                if (item.author_name) {
                                                    const len = item.author_name.length;
                                                    if (len === 2) {
                                                        maskedName = item.author_name[0] + '*';
                                                    } else if (len > 2) {
                                                        maskedName = item.author_name[0] + '*'.repeat(len - 2) + item.author_name[len - 1];
                                                    } else {
                                                        maskedName = item.author_name;
                                                    }
                                                }
                                            %>
                                            <tr>
                                                <td class="col-num"><%= list.length - index %></td>
                                                <td class="col-subject private-post">
                                                    <svg class="icon-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                                    </svg>
                                                    <span>비밀글입니다.</span>
                                                </td>
                                                <td class="col-author"><%= maskedName %></td>
                                                <td class="col-date"><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                                <td class="col-status">
                                                    <span class="badge-status <%= item.status === 'complete' ? 'status-complete' : 'status-pending' %>">
                                                        <%= item.status === 'complete' ? '답변완료' : '접수완료' %>
                                                    </span>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else if (activeTab === 'voice') { %>
                                        <tr>
                                            <td colspan="5" style="text-align: center; padding: 50px; color: rgba(255,255,255,0.4);">접수된 고객의 소리가 존재하지 않습니다.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <!-- 모바일용 디브 카드 목록 -->
                        <div class="mobile-board-card-list">
                            <% if (activeTab === 'voice' && list && list.length > 0) { %>
                                <% list.forEach((item, index) => { %>
                                    <% 
                                        let maskedName = '익명';
                                        if (item.author_name) {
                                            const len = item.author_name.length;
                                            if (len === 2) {
                                                maskedName = item.author_name[0] + '*';
                                            } else if (len > 2) {
                                                maskedName = item.author_name[0] + '*'.repeat(len - 2) + item.author_name[len - 1];
                                            } else {
                                                maskedName = item.author_name;
                                            }
                                        }
                                    %>
                                    <div class="mobile-comm-card">
                                        <div class="card-meta-top">
                                            <span class="card-num-badge">No. <%= list.length - index %></span>
                                            <span class="meta-separator">|</span>
                                            <span class="meta-author" style="font-size: 11.5px; color: rgba(255,255,255,0.5);"><%= maskedName %></span>
                                        </div>
                                        <h4 class="card-title private-post">
                                            <svg class="icon-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px; color: rgba(255,255,255,0.4);">
                                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                            </svg>
                                            <span>비밀글입니다.</span>
                                        </h4>
                                        <div class="card-meta-bottom">
                                            <span class="meta-date"><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></span>
                                        </div>
                                        <div class="card-status-wrap">
                                            <span class="badge-status <%= item.status === 'complete' ? 'status-complete' : 'status-pending' %>">
                                                <%= item.status === 'complete' ? '답변완료' : '접수완료' %>
                                            </span>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else if (activeTab === 'voice') { %>
                                <div class="no-data-msg">접수된 고객의 소리가 존재하지 않습니다.</div>
                            <% } %>
                        </div>
                    </div>
                </div>

                <!-- 4. 문의게시판 (Inquiry) -->
                <div class="comm-panel <%= activeTab === 'inquiry' ? 'active' : '' %>" data-panel="inquiry">
                    <!-- 문의 비밀글 리스트 -->
                    <div class="comm-list-wrap">
                        <div class="comm-list-header">
                            <h4 class="comm-list-title">가맹/비즈니스 문의 현황</h4>
                            <button type="button" class="btn-open-voice-modal" id="btnOpenInquiryModal">
                                <span>문의 접수하기</span>
                                <svg class="btn-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                            </button>
                        </div>
                        
                        <!-- 데스크톱용 테이블 목록 -->
                        <div class="board-table-wrap desktop-only-table">
                            <table class="board-table">
                                <thead>
                                    <tr>
                                        <th class="col-num">번호</th>
                                        <th class="col-subject">제목</th>
                                        <th class="col-author">작성자</th>
                                        <th class="col-date">등록일</th>
                                        <th class="col-status">처리상태</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% if (activeTab === 'inquiry' && list && list.length > 0) { %>
                                        <% list.forEach((item, index) => { %>
                                            <% 
                                                let maskedName = '익명';
                                                if (item.author_name) {
                                                    const len = item.author_name.length;
                                                    if (len === 2) {
                                                        maskedName = item.author_name[0] + '*';
                                                    } else if (len > 2) {
                                                        maskedName = item.author_name[0] + '*'.repeat(len - 2) + item.author_name[len - 1];
                                                    } else {
                                                        maskedName = item.author_name;
                                                    }
                                                }
                                            %>
                                            <tr>
                                                <td class="col-num"><%= list.length - index %></td>
                                                <td class="col-subject private-post">
                                                    <svg class="icon-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                                        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                                        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                                    </svg>
                                                    <span>비밀글입니다.</span>
                                                </td>
                                                <td class="col-author"><%= maskedName %></td>
                                                <td class="col-date"><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                                <td class="col-status">
                                                    <span class="badge-status <%= item.status === 'complete' ? 'status-complete' : 'status-pending' %>">
                                                        <%= item.status === 'complete' ? '답변완료' : '답변대기' %>
                                                    </span>
                                                </td>
                                            </tr>
                                        <% }) %>
                                    <% } else if (activeTab === 'inquiry') { %>
                                        <tr>
                                            <td colspan="5" style="text-align: center; padding: 50px; color: rgba(255,255,255,0.4);">접수된 가맹 및 제휴 문의가 존재하지 않습니다.</td>
                                        </tr>
                                    <% } %>
                                </tbody>
                            </table>
                        </div>

                        <!-- 모바일용 디브 카드 목록 -->
                        <div class="mobile-board-card-list">
                            <% if (activeTab === 'inquiry' && list && list.length > 0) { %>
                                <% list.forEach((item, index) => { %>
                                    <% 
                                        let maskedName = '익명';
                                        if (item.author_name) {
                                            const len = item.author_name.length;
                                            if (len === 2) {
                                                maskedName = item.author_name[0] + '*';
                                            } else if (len > 2) {
                                                maskedName = item.author_name[0] + '*'.repeat(len - 2) + item.author_name[len - 1];
                                            } else {
                                                maskedName = item.author_name;
                                            }
                                        }
                                    %>
                                    <div class="mobile-comm-card">
                                        <div class="card-meta-top">
                                            <span class="card-num-badge">No. <%= list.length - index %></span>
                                            <span class="meta-separator">|</span>
                                            <span class="meta-author" style="font-size: 11.5px; color: rgba(255,255,255,0.5);"><%= maskedName %></span>
                                        </div>
                                        <h4 class="card-title private-post">
                                            <svg class="icon-lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 14px; height: 14px; color: rgba(255,255,255,0.4);">
                                                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                                                <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                                            </svg>
                                            <span>비밀글입니다.</span>
                                        </h4>
                                        <div class="card-meta-bottom">
                                            <span class="meta-date"><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></span>
                                        </div>
                                        <div class="card-status-wrap">
                                            <span class="badge-status <%= item.status === 'complete' ? 'status-complete' : 'status-pending' %>">
                                                <%= item.status === 'complete' ? '답변완료' : '답변대기' %>
                                            </span>
                                        </div>
                                    </div>
                                <% }) %>
                            <% } else if (activeTab === 'inquiry') { %>
                                <div class="no-data-msg">접수된 가맹 및 제휴 문의가 존재하지 않습니다.</div>
                            <% } %>
                        </div>
                    </div>
                </div>

            </div>

        </div>
    </section>

    <!-- 고객의 소리 접수 모달 팝업 -->
    <div class="comm-modal-wrap" id="commVoiceModal">
        <div class="comm-modal-overlay" id="commVoiceModalOverlay"></div>
        <div class="comm-modal-content">
            <button type="button" class="comm-modal-close" id="btnCloseVoiceModal" aria-label="닫기">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <div class="inquiry-intro">
                <h3 class="box-title">고객 불편/불만 접수</h3>
                <p class="box-desc">물고기자리 매장을 이용하시면서 겪으신 불편이나 불만 사항을 남겨주시면 대표가 직접 확인하고 신속히 개선하겠습니다. 모든 내용은 비밀글로 안전하게 접수됩니다.</p>
            </div>
            <form class="comm-inquiry-form" id="commVoiceForm">
                <div class="form-row">
                    <div class="form-col">
                        <label for="commVoiceName" class="form-label">작성자 성함 <span class="required-dot"></span></label>
                        <input type="text" id="commVoiceName" class="form-control" placeholder="성함을 입력하세요." required>
                    </div>
                    <div class="form-col">
                        <label for="commVoicePhone" class="form-label">연락처 <span class="required-dot"></span></label>
                        <input type="tel" id="commVoicePhone" class="form-control" placeholder="연락처를 입력하세요." required>
                    </div>
                </div>

                <div class="form-group-full">
                    <label for="commVoiceContent" class="form-label">불편/불만 사항 <span class="required-dot"></span></label>
                    <textarea id="commVoiceContent" class="form-control text-area" placeholder="불편을 겪으신 구체적인 내용을 작성해 주세요. (비밀글로 접수됩니다)" required></textarea>
                </div>

                <div class="form-agreement-wrap">
                    <label class="agreement-label">
                        <input type="checkbox" id="commVoicePrivacyAgree" checked required>
                        <span class="checkbox-box"></span>
                        <span class="agreement-text">개인정보 수집 및 이용약관에 동의합니다.</span>
                    </label>
                </div>

                <div class="form-btn-submit-wrap">
                    <button type="submit" class="btn-comm-submit">
                        <span>불편/불만 접수하기 (비밀글)</span>
                        <svg class="submit-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- 가맹 및 제휴 문의 접수 모달 팝업 -->
    <div class="comm-modal-wrap" id="commInquiryModal">
        <div class="comm-modal-overlay" id="commInquiryModalOverlay"></div>
        <div class="comm-modal-content">
            <button type="button" class="comm-modal-close" id="btnCloseInquiryModal" aria-label="닫기">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <line x1="18" y1="6" x2="6" y2="18"></line>
                    <line x1="6" y1="6" x2="18" y2="18"></line>
                </svg>
            </button>
            <div class="inquiry-intro">
                <h3 class="box-title">가맹 및 제휴 문의</h3>
                <p class="box-desc">물고기자리 성공 창업을 위한 가맹 상담, 개설 문의, 비즈니스 제휴 제안을 남겨주시면 가맹본부 담당자가 신속히 확인하여 답변을 드리겠습니다.</p>
            </div>
            
            <form class="comm-inquiry-form" id="commInquiryForm">
                <div class="form-row">
                    <div class="form-col">
                        <label for="commInquirerName" class="form-label">작성자 성함 <span class="required-dot"></span></label>
                        <input type="text" id="commInquirerName" class="form-control" placeholder="성함을 입력하세요." required>
                    </div>
                    <div class="form-col">
                        <label for="commInquirerPhone" class="form-label">연락처 <span class="required-dot"></span></label>
                        <input type="tel" id="commInquirerPhone" class="form-control" placeholder="연락처를 입력하세요." required>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-col">
                        <label for="commInquiryType" class="form-label">문의 분류 <span class="required-dot"></span></label>
                        <select id="commInquiryType" class="form-control select-control" required>
                            <option value="franchise">신규 가맹 / 창업 상담 문의</option>
                            <option value="location">매장 개설 / 상권 분석 문의</option>
                            <option value="alliance">비즈니스 제휴 / 납품 문의</option>
                            <option value="other">기타 문의사항</option>
                        </select>
                    </div>
                    <div class="form-col">
                        <label for="commInquirerEmail" class="form-label">이메일 주소</label>
                        <input type="email" id="commInquirerEmail" class="form-control" placeholder="이메일(선택)을 입력하세요.">
                    </div>
                </div>

                <div class="form-group-full">
                    <label for="commInquiryContent" class="form-label">문의 내용 <span class="required-dot"></span></label>
                    <textarea id="commInquiryContent" class="form-control text-area" placeholder="문의하실 구체적인 내용을 작성해 주세요." required></textarea>
                </div>

                <div class="form-agreement-wrap">
                    <label class="agreement-label">
                        <input type="checkbox" id="commPrivacyAgree" checked required>
                        <span class="checkbox-box"></span>
                        <span class="agreement-text">개인정보 수집 및 이용약관에 동의합니다.</span>
                    </label>
                </div>

                <div class="form-btn-submit-wrap">
                    <button type="submit" class="btn-comm-submit">
                        <span>문의 접수하기 (비밀글)</span>
                        <svg class="submit-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                        </svg>
                    </button>
                </div>
            </form>
        </div>
    </div>

    <!-- Scroll to Top Button -->
    <button type="button" id="btnScrollTop" class="btn-scroll-top" aria-label="맨 위로 스크롤">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="18 15 12 9 6 15"></polyline>
        </svg>
    </button>

    <script>
        // 1. 탭 버튼 및 모바일 그리드 탭 클릭 이벤트 (SSR 페이지 이동 처리)
        const tabButtons = document.querySelectorAll('.comm-tab-btn, .comm-mobile-grid-btn');
        tabButtons.forEach(btn => {
            btn.addEventListener('click', () => {
                const targetTab = btn.dataset.tab;
                location.href = `/community/${targetTab}`;
            });
        });

        // 2. 실시간 프론트엔드 게시글 검색 필터 스크립트
        const commSearchInput = document.getElementById('commSearchInput');
        const btnCommSearch = document.getElementById('btnCommSearch');

        function filterCommunityItems() {
            const query = commSearchInput.value.trim().toLowerCase();
            
            // A. 테이블 기반 리스트 필터링 (공지사항, 고객의소리, 문의사항)
            const tableRows = document.querySelectorAll('.board-table tbody tr');
            tableRows.forEach(row => {
                if (row.cells.length === 1 && row.cells[0].getAttribute('colspan')) return; // 데이터 없음 행 예외처리

                const textContent = row.textContent.toLowerCase();
                if (textContent.includes(query)) {
                    row.style.setProperty('display', '', 'important');
                } else {
                    row.style.setProperty('display', 'none', 'important');
                }
            });

            // B. 아코디언 FAQ 목록 필터링
            const faqItems = document.querySelectorAll('.faq-item');
            faqItems.forEach(item => {
                const questionText = item.querySelector('.faq-q-text').textContent.toLowerCase();
                const answerText = item.querySelector('.faq-answer').textContent.toLowerCase();
                if (questionText.includes(query) || answerText.includes(query)) {
                    item.style.setProperty('display', '', 'important');
                } else {
                    item.style.setProperty('display', 'none', 'important');
                    // 닫기 상태로 초기화
                    item.classList.remove('active');
                    const answer = item.querySelector('.faq-answer');
                    if (answer) answer.style.maxHeight = null;
                    const icon = item.querySelector('.faq-arrow-icon');
                    if (icon) icon.innerHTML = '&plus;';
                }
            });
        }

        if (commSearchInput) {
            commSearchInput.addEventListener('input', filterCommunityItems);
            commSearchInput.addEventListener('keydown', (e) => {
                if (e.key === 'Enter') {
                    filterCommunityItems();
                }
            });
        }
        if (btnCommSearch) {
            btnCommSearch.addEventListener('click', filterCommunityItems);
        }

        // 2. 공지사항 상세 내용 접기/펴기 토글 기능
        function toggleNoticeContent(id) {
            const contentBox = document.getElementById(`notice-content-${id}`);
            if (contentBox) {
                if (contentBox.style.display === 'none') {
                    // 열 때 다른 모든 열려있는 공지 접기
                    document.querySelectorAll('.notice-content-fold').forEach(box => {
                        box.style.display = 'none';
                    });
                    contentBox.style.display = 'block';
                } else {
                    contentBox.style.display = 'none';
                }
            }
        }

        // 모바일용 공지사항 상세 내용 접기/펴기 토글 기능
        function toggleNoticeContentMobile(id) {
            const contentBox = document.getElementById(`notice-content-mobile-${id}`);
            if (contentBox) {
                if (contentBox.style.display === 'none') {
                    // 열 때 다른 모든 열려있는 공지 접기
                    document.querySelectorAll('.mobile-comm-card .notice-content-fold').forEach(box => {
                        box.style.display = 'none';
                    });
                    contentBox.style.display = 'block';
                } else {
                    contentBox.style.display = 'none';
                }
            }
        }

        // 3. FAQ 아코디언 토글 기능
        const faqQuestions = document.querySelectorAll('.faq-question');
        faqQuestions.forEach(q => {
            q.addEventListener('click', () => {
                const item = q.parentElement;
                const answer = q.nextElementSibling;
                const icon = q.querySelector('.faq-arrow-icon');
                
                const isOpen = item.classList.contains('active');
                
                // 모든 FAQ 닫기
                document.querySelectorAll('.faq-item').forEach(el => {
                    el.classList.remove('active');
                    el.querySelector('.faq-answer').style.maxHeight = null;
                    el.querySelector('.faq-arrow-icon').innerHTML = '&plus;';
                });
                
                if (!isOpen) {
                    item.classList.add('active');
                    answer.style.maxHeight = answer.scrollHeight + 'px';
                    icon.innerHTML = '&minus;';
                }
            });
        });

        // 4. 모달 열기/닫기 처리
        const setupModal = (btnOpenId, modalId, btnCloseId, overlayId) => {
            const btnOpen = document.getElementById(btnOpenId);
            const modal = document.getElementById(modalId);
            const btnClose = document.getElementById(btnCloseId);
            const overlay = document.getElementById(overlayId);

            if (btnOpen && modal && btnClose && overlay) {
                const openModal = () => modal.classList.add('active');
                const closeModal = () => modal.classList.remove('active');

                btnOpen.addEventListener('click', openModal);
                btnClose.addEventListener('click', closeModal);
                overlay.addEventListener('click', closeModal);
            }
        };

        setupModal('btnOpenVoiceModal', 'commVoiceModal', 'btnCloseVoiceModal', 'commVoiceModalOverlay');
        setupModal('btnOpenInquiryModal', 'commInquiryModal', 'btnCloseInquiryModal', 'commInquiryModalOverlay');

        // 5. 고객의 소리 (Voice) 비동기 접수 처리
        const voiceForm = document.getElementById('commVoiceForm');
        if (voiceForm) {
            voiceForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                const name = document.getElementById('commVoiceName').value;
                const phone = document.getElementById('commVoicePhone').value;
                const content = document.getElementById('commVoiceContent').value;
                const privacyAgree = document.getElementById('commVoicePrivacyAgree').checked;

                if (!privacyAgree) {
                    alert('개인정보 수집 및 이용약관에 동의하셔야 접수가 가능합니다.');
                    return;
                }

                try {
                    const response = await fetch('/api/community/voice', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ name, phone, content })
                    });

                    const data = await response.json();
                    if (data.success) {
                        alert(data.message || '성공적으로 접수되었습니다.');
                        location.reload(); // 새로고침해서 리스트 갱신
                    } else {
                        alert(data.message || '접수에 실패했습니다.');
                    }
                } catch (err) {
                    console.error('Submit voice error:', err);
                    alert('네트워크 오류로 접수에 실패했습니다.');
                }
            });
        }

        // 6. 가맹 및 제휴 문의 (Inquiry) 비동기 접수 처리
        const inquiryForm = document.getElementById('commInquiryForm');
        if (inquiryForm) {
            inquiryForm.addEventListener('submit', async (e) => {
                e.preventDefault();

                const name = document.getElementById('commInquirerName').value;
                const phone = document.getElementById('commInquirerPhone').value;
                const type = document.getElementById('commInquiryType').value;
                const email = document.getElementById('commInquirerEmail').value;
                const content = document.getElementById('commInquiryContent').value;
                const privacyAgree = document.getElementById('commPrivacyAgree').checked;

                if (!privacyAgree) {
                    alert('개인정보 수집 및 이용약관에 동의하셔야 접수가 가능합니다.');
                    return;
                }

                try {
                    const response = await fetch('/api/community/inquiry', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ name, phone, email, type, content })
                    });

                    const data = await response.json();
                    if (data.success) {
                        alert(data.message || '성공적으로 문의가 접수되었습니다.');
                        location.reload(); // 새로고침해서 리스트 갱신
                    } else {
                        alert(data.message || '문의 접수에 실패했습니다.');
                    }
                } catch (err) {
                    console.error('Submit inquiry error:', err);
                    alert('네트워크 오류로 접수에 실패했습니다.');
                }
            });
        }
    </script>

