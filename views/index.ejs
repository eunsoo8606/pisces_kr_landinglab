    <!-- 메인 팝업 노출 마크업 및 스크립트 -->
    <% if (typeof popups !=='undefined' && popups.length> 0) { %>
        <style>
            /* 레이어 팝업 스타일 */
            .custom-popup-layer {
                position: fixed;
                background: #ffffff;
                border: 1px solid #cbd5e1;
                border-radius: 12px;
                box-shadow: 0 10px 35px rgba(15, 23, 42, 0.15);
                z-index: 1000;
                display: none;
                /* JS 제어 시까지 기본 숨김 */
                flex-direction: column;
                overflow: hidden;
            }

            .popup-layer-content {
                flex: 1;
                overflow: hidden;
            }

            .popup-layer-content img {
                width: 100%;
                height: 100%;
                object-fit: cover;
                display: block;
            }

            .popup-layer-footer {
                height: 40px;
                background: #1e293b;
                display: flex;
                justify-content: space-between;
                align-items: center;
                padding: 0 16px;
                color: #ffffff;
                font-size: 12px;
            }

            .popup-close-today {
                display: inline-flex;
                align-items: center;
                gap: 6px;
                cursor: pointer;
                user-select: none;
            }

            .popup-close-today input {
                cursor: pointer;
                accent-color: #0284c7;
                width: 14px;
                height: 14px;
                margin: 0;
            }

            .btn-popup-close {
                background: none;
                border: none;
                color: #ffffff;
                font-weight: 700;
                cursor: pointer;
                padding: 4px 8px;
                font-size: 12px;
            }

            .btn-popup-close:hover {
                text-decoration: underline;
            }

            /* 모바일 반응형 처리 */
            @media (max-width: 768px) {
                .custom-popup-layer {
                    left: 5% !important;
                    right: 5% !important;
                    width: 90% !important;
                    margin: 0 auto;
                }
            }
        </style>

        <!-- 레이어 팝업 컨테이너 -->
        <div id="landing-popups">
            <% popups.forEach(popup=> { %>
                <div id="popup-layer-<%= popup.id %>" class="custom-popup-layer"
                    style="width: <%= popup.width %>px; height: <%= popup.height %>px; top: <%= popup.position_top %>px; left: <%= popup.position_left %>px;">
                    <div class="popup-layer-content">
                        <% if (popup.link_url) { %>
                            <a href="<%= popup.link_url %>" target="<%= popup.target %>">
                                <img src="<%= popup.image_url %>" alt="<%= popup.title %>">
                            </a>
                            <% } else { %>
                                <img src="<%= popup.image_url %>" alt="<%= popup.title %>">
                                <% } %>
                    </div>
                    <div class="popup-layer-footer">
                        <label class="popup-close-today">
                            <input type="checkbox" id="close-today-<%= popup.id %>">
                            <span>오늘 하루 열지 않기</span>
                        </label>
                        <button type="button" class="btn-popup-close"
                            onclick="closePopupLayer('<%= popup.id %>')">닫기</button>
                    </div>
                </div>
                <% }) %>
        </div>

        <script>
            // 팝업 닫기 및 오늘 하루 열지 않기 처리
            function closePopupLayer(id) {
                const layer = document.getElementById(`popup-layer-${id}`);
                const checkCloseToday = document.getElementById(`close-today-${id}`);

                if (layer) {
                    layer.style.display = 'none';

                    if (checkCloseToday && checkCloseToday.checked) {
                        // 24시간(오늘 하루) 보지 않기 설정 (Expiry Time 지정)
                        const expiryDate = new Date();
                        expiryDate.setTime(expiryDate.getTime() + (24 * 60 * 60 * 1000));
                        localStorage.setItem(`popup_hide_${id}`, expiryDate.getTime());
                    }
                }
            }

            // 초기 로딩 시 오늘 하루 열지 않기 상태 검사
            document.addEventListener('DOMContentLoaded', () => {
                const now = new Date().getTime();
                const popupLayers = document.querySelectorAll('.custom-popup-layer');

                popupLayers.forEach(layer => {
                    const idStr = layer.id.replace('popup-layer-', '');
                    const hideExpiry = localStorage.getItem(`popup_hide_${idStr}`);

                    if (hideExpiry && now < parseInt(hideExpiry, 10)) {
                        layer.style.display = 'none';
                    } else {
                        if (hideExpiry) {
                            localStorage.removeItem(`popup_hide_${idStr}`);
                        }
                        layer.style.display = 'flex';
                    }
                });
            });
        </script>
        <% } %>

            <%- include('layout/footer') %>