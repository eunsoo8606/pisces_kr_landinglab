    <!-- 모바일 자체 필렛시스템 인터랙티브 포커스 사이클 스크립트 -->
    <script>
        document.addEventListener('DOMContentLoaded', () => {
            // 모바일 768px 이하 환경에서만 동작하도록 한정
            if (window.innerWidth <= 768) {
                const items = document.querySelectorAll('.hero-features .feature-item');
                if (items.length === 0) return;

                let currentIndex = 0;
                let cycleInterval = null;
                let pauseTimeout = null;

                // 선택된 아이템을 활성화하고 이전 활성 아이템을 비활성화하는 함수
                function activateItem(index) {
                    items.forEach((item, idx) => {
                        if (idx === index) {
                            item.classList.add('active');
                        } else {
                            item.classList.remove('active');
                        }
                    });
                    currentIndex = index;
                }

                // 3초 간격으로 강점 카테고리가 자동 롤링되도록 사이클 가동
                function startCycle() {
                    if (cycleInterval) clearInterval(cycleInterval);
                    cycleInterval = setInterval(() => {
                        let nextIndex = (currentIndex + 1) % items.length;
                        activateItem(nextIndex);
                    }, 3000);
                }

                // 사용자가 임의의 항목을 누르면 자동 전환을 멈추고 8초 후 재개
                function pauseCycle() {
                    if (cycleInterval) clearInterval(cycleInterval);
                    if (pauseTimeout) clearTimeout(pauseTimeout);
                    pauseTimeout = setTimeout(() => {
                        startCycle();
                    }, 8000);
                }

                // 최초 진입 시 첫 번째 항목 활성화 및 롤링 개시
                activateItem(0);
                startCycle();

                // 클릭 또는 터치 시 즉시 활성화 및 롤링 정지(딜레이) 트리거
                items.forEach((item, idx) => {
                    item.addEventListener('click', () => {
                        activateItem(idx);
                        pauseCycle();
                    });
                });
            }
        });
    </script>

