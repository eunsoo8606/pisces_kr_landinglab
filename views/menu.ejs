                        <div class="menu-card">
                            <img src="/images/foods/새우가스.jpg" alt="새우가스">
                            <div class="menu-card-info">
                                <span class="card-category">KIDS</span>
                                <h3 class="card-name">새우 가스</h3>
                                <span class="card-price">14,000원</span>
                            </div>
                        </div>
                        <div class="menu-card">
                            <img src="/images/foods/볶음우동.jpg" alt="볶음우동">
                            <div class="menu-card-info">
                                <span class="card-category">NOODLE</span>
                                <h3 class="card-name">볶음 우동</h3>
                                <span class="card-price">12,000원</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 점심특선 -->
                <div class="menu-panel <%= activeTab === 'lunch' ? 'active' : '' %>" data-panel="lunch">
                    <div class="menu-grid">
                        <div class="menu-card main-card">
                            <img src="/images/foods/물고기자리 연출컷-10.jpg" alt="점심특선">
                            <div class="menu-card-info">
                                <span class="card-category">LUNCH</span>
                                <h3 class="card-name">점심 특선 A코스</h3>
                                <span class="card-price">30,000원</span>
                            </div>
                        </div>
                        <div class="menu-card">
                            <img src="/images/foods/라면.jpg" alt="라면">
                            <div class="menu-card-info">
                                <span class="card-category">SIMPLE</span>
                                <h3 class="card-name">점심 라면 세트</h3>
                                <span class="card-price">10,000원</span>
                            </div>
                        </div>
                        <div class="menu-card">
                            <img src="/images/foods/돈가스.jpg" alt="돈가스">
                            <div class="menu-card-info">
                                <span class="card-category">LUNCH</span>
