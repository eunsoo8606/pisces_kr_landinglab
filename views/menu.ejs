                            <img src="/images/foods/물고기자리 연출컷-11.jpg" alt="점심2">
                            <div class="menu-card-info">
                                <span class="card-category">LUNCH</span>
                                <h3 class="card-name">점심 특선 B코스</h3>
                                <span class="card-price">38,000원</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 세트메뉴 -->
                <div class="menu-panel <%= activeTab === 'set' ? 'active' : '' %>" data-panel="set">
                    <div class="menu-grid">
                        <div class="menu-card main-card">
                            <img src="/images/foods/물고기자리 연출컷-12.jpg" alt="세트">
                            <div class="menu-card-info">
                                <span class="card-category">SET A</span>
                                <h3 class="card-name">2인 프리미엄 세트</h3>
                                <span class="card-price">98,000원</span>
                            </div>
                        </div>
                        <div class="menu-card">
                            <img src="/images/foods/물고기자리 연출컷-3.jpg" alt="세트2">
                            <div class="menu-card-info">
                                <span class="card-category">SET B</span>
                                <h3 class="card-name">4인 가족 세트</h3>
                                <span class="card-price">178,000원</span>
                            </div>
                        </div>
                        <div class="menu-card">
                            <img src="/images/foods/물고기자리 연출컷-6.jpg" alt="세트3">
                            <div class="menu-card-info">
                                <span class="card-category">SET C</span>
