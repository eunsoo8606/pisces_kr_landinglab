                            </div>
                        </div>
                        <div class="menu-card">
                            <img src="/images/foods/마끼.jpg" alt="마끼">
                            <div class="menu-card-info">
                                <span class="card-category">SPECIAL</span>
                                <h3 class="card-name">모둠 마끼</h3>
                                <span class="card-price">22,000원</span>
                            </div>
                        </div>
                        <div class="menu-card">
                            <img src="/images/foods/마늘버섯구이.jpg" alt="마늘버섯구이">
                            <div class="menu-card-info">
                                <span class="card-category">GRILLED</span>
                                <h3 class="card-name">마늘버섯구이</h3>
                                <span class="card-price">16,000원</span>
                            </div>
                        </div>
                        <div class="menu-card">
                            <img src="/images/foods/물고기자리 연출컷-7.jpg" alt="연출컷7">
                            <div class="menu-card-info">
                                <span class="card-category">LIMITED</span>
                                <h3 class="card-name">특선 코스</h3>
                                <span class="card-price">시가</span>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- 사이드 -->
                <div class="menu-panel <%= activeTab === 'side' ? 'active' : '' %>" data-panel="side">
                    <div class="menu-grid">
                        <div class="menu-card main-card">
                            <img src="/images/foods/skidashe.webp" alt="모듬튀김">
                            <div class="menu-card-info">
                                <span class="card-category">SIDE</span>
                                <h3 class="card-name">모둠 튀김</h3>
                                <span class="card-price">18,000원</span>
                            </div>
                        </div>
                        <div class="menu-card">
                            <img src="/images/foods/닭강정.jpg" alt="닭강정">
