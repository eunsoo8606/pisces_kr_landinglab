<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
    <link rel="icon" href="/favicon.webp?v=2" type="image/png">
    <style>
        /* 프리미엄 라이트 테마 */
        body {
            background-color: #f8fafc;
            color: #334155;
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        .dashboard-layout {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        /* 1. 좌측 고정 사이드바 */
        .console-sidebar {
            width: 270px;
            background: #ffffff;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 100;
            box-sizing: border-box;
            box-shadow: 4px 0 20px rgba(15, 23, 42, 0.02);
            transition: transform 0.3s ease;
        }

        .sidebar-logo {
            padding: 28px 24px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
        }

        .sidebar-logo img {
            height: 38px;
            width: auto;
        }

        .sidebar-logo span {
            color: #0284c7;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            border: 1px solid rgba(2, 132, 199, 0.25);
            padding: 2px 6px;
            border-radius: 4px;
            background-color: rgba(2, 132, 199, 0.05);
            letter-spacing: 0.5px;
        }

        .sidebar-menu {
            flex: 1;
            padding: 30px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            overflow-y: auto;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #475569;
            text-decoration: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            transition: all 0.25s ease;
            cursor: pointer;
            border: 1px solid transparent;
            box-sizing: border-box;
        }

        .menu-item svg {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            color: #64748b;
            transition: transform 0.2s ease;
        }

        .menu-item:hover {
            color: #0284c7;
            background: #f8fafc;
        }

        .menu-item:hover svg {
            transform: translateX(2px);
            color: #0284c7;
        }

        .menu-item.active {
            color: #0284c7;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        .menu-item.active svg {
            color: #0284c7;
        }

        .menu-item.sub-item {
            font-size: 13px;
            padding: 8px 18px 8px 30px;
            color: #64748b;
        }

        .menu-item.sub-item.active {
            color: #0369a1;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        /* 2. 우측 메인 콘텐츠 영역 */
        .console-main {
            margin-left: 270px;
            flex: 1;
            padding: 40px 50px;
            box-sizing: border-box;
            min-width: 0;
            transition: margin-left 0.3s ease;
        }

        /* 모바일 햄버거 헤더 */
        .mobile-header {
            display: none;
            justify-content: space-between;
            align-items: center;
            background: #ffffff;
            padding: 15px 20px;
            border-bottom: 1px solid #e2e8f0;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .mobile-menu-btn {
            background: none;
            border: none;
            color: #0f172a;
            cursor: pointer;
            padding: 5px;
        }

        .mobile-menu-btn svg {
            width: 24px;
            height: 24px;
        }

        /* 상단 타이틀 바 */
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 20px;
        }

        .main-header-title h2 {
            font-size: 26px;
            font-weight: 800;
            margin: 0;
            color: #0f172a;
            letter-spacing: -0.5px;
        }

        .main-header-title p {
            font-size: 13px;
            color: #64748b;
            margin: 6px 0 0 0;
        }

        .header-profile-wrap {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            padding: 8px 16px;
            border-radius: 12px;
        }

        .user-profile {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .user-name {
            font-size: 13px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }

        .user-role {
            font-size: 10px;
            color: #64748b;
            margin: 0;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 6px 12px;
            background: rgba(239, 68, 68, 0.06);
            border: 1px solid rgba(239, 68, 68, 0.15);
            color: #ef4444;
            font-size: 12px;
            font-weight: 700;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.25s ease;
        }

        .btn-logout:hover {
            background: #ef4444;
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.15);
        }

        /* 컨트롤 바 */
        .board-controls {
            display: flex;
            justify-content: space-between;
            align-items: center;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 20px 24px;
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
            margin-bottom: 24px;
        }

        .control-desc {
            font-size: 13px;
            color: #64748b;
            font-weight: 600;
        }

        .btn-write {
            padding: 10px 24px;
            background: #0f172a;
            border: 1px solid #0f172a;
            color: #ffffff;
            font-size: 13px;
            font-weight: 700;
            border-radius: 10px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.25s ease;
        }

        .btn-write:hover {
            background: #1e293b;
            border-color: #1e293b;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
        }

        /* 테이블 카드 레이아웃 */
        .table-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .table-container {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            white-space: nowrap;
        }

        th {
            padding: 16px;
            color: #64748b;
            font-weight: 700;
            border-bottom: 1.5px solid #e2e8f0;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: left;
            background-color: #f8fafc;
        }

        td {
            padding: 16px;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
            vertical-align: middle;
        }

        tr:hover td {
            background: #f8fafc;
        }

        /* 썸네일 이미지 미리보기 */
        .popup-thumb {
            width: 70px;
            height: 70px;
            border-radius: 8px;
            object-fit: cover;
            border: 1px solid #cbd5e1;
            cursor: pointer;
            transition: transform 0.2s ease;
        }

        .popup-thumb:hover {
            transform: scale(1.1);
        }

        /* 토글 스위치 스타일 */
        .switch {
            position: relative;
            display: inline-block;
            width: 44px;
            height: 24px;
        }

        .switch input {
            opacity: 0;
            width: 0;
            height: 0;
        }

        .slider {
            position: absolute;
            cursor: pointer;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-color: #cbd5e1;
            transition: .3s;
            border-radius: 24px;
        }

        .slider:before {
            position: absolute;
            content: "";
            height: 18px;
            width: 18px;
            left: 3px;
            bottom: 3px;
            background-color: white;
            transition: .3s;
            border-radius: 50%;
        }

        input:checked + .slider {
            background-color: #10b981;
        }

        input:focus + .slider {
            box-shadow: 0 0 1px #10b981;
        }

        input:checked + .slider:before {
            transform: translateX(20px);
        }

        /* 팝업 노출 상태 배지 */
        .badge-status {
            display: inline-block;
            padding: 4px 8px;
            border-radius: 6px;
            font-size: 11px;
            font-weight: bold;
        }

        .status-running {
            background-color: #dcfce7;
            color: #15803d;
            border: 1px solid #bbf7d0;
        }

        .status-waiting {
            background-color: #fef9c3;
            color: #a16207;
            border: 1px solid #fef08a;
        }

        .status-expired {
            background-color: #fee2e2;
            color: #b91c1c;
            border: 1px solid #fecaca;
        }

        .status-stopped {
            background-color: #f1f5f9;
            color: #475569;
            border: 1px solid #e2e8f0;
        }

        /* 액션 링크 및 버튼 */
        .action-links {
            display: flex;
            gap: 10px;
        }

        .btn-action-edit {
            color: #0284c7;
            text-decoration: none;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-action-edit:hover {
            color: #0369a1;
            text-decoration: underline;
        }

        .btn-action-del {
            color: #ef4444;
            background: none;
            border: none;
            font-weight: 700;
            cursor: pointer;
            padding: 0;
            font-family: inherit;
            font-size: inherit;
        }

        .btn-action-del:hover {
            text-decoration: underline;
        }

        /* 모바일 네비게이션용 백드롭 */
        .sidebar-backdrop {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.4);
            z-index: 98;
        }

        /* 모바일 반응형 미디어 쿼리 */
        @media (max-width: 992px) {
            .console-sidebar {
                transform: translateX(-100%);
            }
            
            .console-sidebar.open {
                transform: translateX(0);
                box-shadow: 10px 0 35px rgba(15, 23, 42, 0.1);
            }
            
            .console-main {
                margin-left: 0;
                padding: 30px 20px;
            }
            
            .mobile-header {
                display: flex;
            }
            
            .main-header {
                display: none;
            }

            .sidebar-backdrop.open {
                display: block;
            }
        }
    </style>
</head>
<body>
    <!-- 모바일 전용 헤더 -->
    <div class="mobile-header">
        <div style="display: flex; align-items: center; gap: 10px;">
            <button class="mobile-menu-btn" id="btnToggleMenu" aria-label="메뉴 열기">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <img src="/images/logo.webp" alt="물고기자리" style="height: 28px; width: auto;">
        </div>
        <span style="color: #0284c7; font-size: 11px; font-weight: bold; border: 1px solid rgba(2,132,199,0.3); padding: 1px 4px; border-radius: 4px; background: rgba(2,132,199,0.05);">console</span>
    </div>

    <!-- 모바일 사이드바 백드롭 -->
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <div class="dashboard-layout">
        <!-- 좌측 고정 사이드바 -->
        <div class="console-sidebar" id="consoleSidebar">
            <div class="sidebar-logo">
                <img src="/images/logo.webp" alt="물고기자리 로고">
                <span>console</span>
            </div>
            
            <div class="sidebar-menu">
                <!-- 1. 대쉬보드 -->
                <a href="/console/dashboard" class="menu-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="9"></rect>
                        <rect x="14" y="3" width="7" height="5"></rect>
                        <rect x="14" y="12" width="7" height="9"></rect>
                        <rect x="3" y="16" width="7" height="5"></rect>
                    </svg>
                    <span>대쉬보드</span>
                </a>

                <!-- 3. 게시판 관리 -->
                <div class="menu-group" style="display: flex; flex-direction: column; gap: 4px; margin-top: 10px;">
                    <div class="menu-group-title" style="padding: 5px 20px; font-size: 11px; font-weight: bold; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;">게시판 관리</div>
                    <a href="/console/board/notice" class="menu-item sub-item">
                        <span>- 공지사항 관리</span>
                    </a>
                    <a href="/console/board/faq" class="menu-item sub-item">
                        <span>- FAQ 관리</span>
                    </a>
                    <a href="/console/board/voice" class="menu-item sub-item">
                        <span>- 고객의 소리 관리</span>
                    </a>
                    <a href="/console/board/inquiry" class="menu-item sub-item">
                        <span>- 문의게시판 관리</span>
                    </a>
                </div>

                <!-- 4. 메뉴(음식) 관리 -->
                <a href="/console/menu" class="menu-item" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                        <path d="M2 12h20"></path>
                    </svg>
                    <span>메뉴(음식) 관리</span>
                </a>

                <!-- 5. 팝업관리 -->
                <a href="/console/popup" class="menu-item active" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="3" x2="9" y2="21"></line>
                        <line x1="17" y1="9" x2="21" y2="9"></line>
                        <line x1="17" y1="15" x2="21" y2="15"></line>
                    </svg>
                    <span>팝업관리</span>
                </a>
            </div>
        </div>

        <!-- 우측 메인 콘텐츠 영역 -->
        <div class="console-main">
            <!-- 메인 헤더 -->
            <div class="main-header">
                <div class="main-header-title">
                    <h2>팝업 관리</h2>
                    <p>메인 홈페이지에 노출할 팝업을 등록하고 노출 기간, 크기 및 활성 여부를 조절합니다.</p>
                </div>
                
                <div style="display: flex; align-items: center; gap: 20px;">
                    <div class="header-profile-wrap">
                        <div class="user-profile">
                            <span class="user-name"><%= adminUser.name %> 님</span>
                            <span class="user-role">최고관리자 (ID: <%= adminUser.username %>)</span>
                        </div>
                        <a href="/console/logout" class="btn-logout">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                <polyline points="16 17 21 12 16 7"></polyline>
                                <line x1="21" y1="12" x2="9" y2="12"></line>
                            </svg>
                            <span>로그아웃</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- 컨트롤 바 -->
            <div class="board-controls">
                <div class="control-desc">
                    등록된 총 팝업 수: <span style="color: #0284c7; font-weight: bold;"><%= list.length %></span>건
                </div>
                <a href="/console/popup/write" class="btn-write">
                    <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="12" y1="5" x2="12" y2="19"></line>
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                    </svg>
                    <span>새 팝업 등록</span>
                </a>
            </div>

            <!-- 데이터 리스트 테이블 -->
            <div class="table-card">
                <div class="table-container">
                    <% if (list && list.length > 0) { %>
                        <table>
                            <thead>
                                <tr>
                                    <th style="width: 70px; text-align: center;">ID</th>
                                    <th style="width: 100px; text-align: center;">이미지</th>
                                    <th>팝업 제목</th>
                                    <th style="width: 150px; text-align: center;">크기 (W x H)</th>
                                    <th style="width: 150px; text-align: center;">위치 (L, T)</th>
                                    <th style="width: 250px;">노출 기간</th>
                                    <th style="width: 100px; text-align: center;">상태</th>
                                    <th style="width: 100px; text-align: center;">노출 여부</th>
                                    <th style="width: 120px; text-align: center;">관리</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% 
                                    const now = new Date();
                                    list.forEach(item => { 
                                        const startDate = new Date(item.start_date);
                                        const endDate = new Date(item.end_date);
                                        
                                        let statusText = '노출중';
                                        let statusClass = 'status-running';
                                        
                                        if (item.is_active === 0) {
                                            statusText = '노출중지';
                                            statusClass = 'status-stopped';
                                        } else if (now < startDate) {
                                            statusText = '노출대기';
                                            statusClass = 'status-waiting';
                                        } else if (now > endDate) {
                                            statusText = '기간만료';
                                            statusClass = 'status-expired';
                                        }
                                %>
                                    <tr id="row-<%= item.id %>">
                                        <td style="text-align: center; color: #94a3b8; font-weight: bold;"><%= item.id %></td>
                                        <td style="text-align: center;">
                                            <img src="<%= item.image_url %>" alt="<%= item.title %>" class="popup-thumb" onclick="window.open('<%= item.image_url %>', '_blank')" onerror="this.src='/images/logo.webp'">
                                        </td>
                                        <td style="font-weight: 700; color: #0f172a;">
                                            <%= item.title %>
                                            <% if (item.link_url) { %>
                                                <div style="font-size: 11px; font-weight: normal; color: #64748b; margin-top: 4px; font-family: monospace;">
                                                    이동: <%= item.link_url %> (<%= item.target %>)
                                                </div>
                                            <% } %>
                                        </td>
                                        <td style="text-align: center; font-weight: bold; color: #334155;">
                                            <%= item.width %> x <%= item.height %> px
                                        </td>
                                        <td style="text-align: center; color: #64748b;">
                                            X: <%= item.position_left %>, Y: <%= item.position_top %>
                                        </td>
                                        <td>
                                            <div style="font-size: 13px; font-weight: 600; color: #334155;">
                                                시작: <%= new Date(item.start_date).toLocaleString('ko-KR') %>
                                            </div>
                                            <div style="font-size: 13px; font-weight: 600; color: #ef4444; margin-top: 4px;">
                                                종료: <%= new Date(item.end_date).toLocaleString('ko-KR') %>
                                            </div>
                                        </td>
                                        <td style="text-align: center;">
                                            <span class="badge-status <%= statusClass %>"><%= statusText %></span>
                                        </td>
                                        <td style="text-align: center;">
                                            <label class="switch">
                                                <input type="checkbox" id="toggle-<%= item.id %>" <%= item.is_active === 1 ? 'checked' : '' %> onchange="togglePopup('<%= item.id %>')">
                                                <span class="slider"></span>
                                            </label>
                                        </td>
                                        <td style="text-align: center;">
                                            <div class="action-links" style="justify-content: center;">
                                                <a href="/console/popup/edit/<%= item.id %>" class="btn-action-edit">수정</a>
                                                <span style="color: #e2e8f0;">|</span>
                                                <button type="button" class="btn-action-del" onclick="deletePopup('<%= item.id %>')">삭제</button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div style="text-align: center; padding: 50px; color: #64748b;">
                            등록된 팝업 데이터 내역이 존재하지 않습니다.
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 비동기 활성화 상태 토글
        async function togglePopup(id) {
            const checkbox = document.getElementById(`toggle-${id}`);
            
            try {
                const response = await fetch(`/api/popup/toggle/${id}`, {
                    method: 'PUT',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();
                if (data.success) {
                    // 성공 시 페이지를 새로고침하여 상태 표시 뱃지 최신화
                    location.reload();
                } else {
                    alert(data.message || '상태 변경에 실패했습니다.');
                    checkbox.checked = !checkbox.checked; // 롤백
                }
            } catch (err) {
                console.error('Toggle error:', err);
                alert('서버 통신 에러가 발생하여 상태 변경에 실패했습니다.');
                checkbox.checked = !checkbox.checked; // 롤백
            }
        }

        // 비동기 팝업 삭제 처리
        async function deletePopup(id) {
            if (!confirm('정말로 이 팝업을 영구 삭제하시겠습니까?')) {
                return;
            }

            try {
                const response = await fetch(`/api/popup/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();
                if (data.success) {
                    alert(data.message || '삭제되었습니다.');
                    const tr = document.getElementById(`row-${id}`);
                    if (tr) {
                        tr.remove();
                    } else {
                        location.reload();
                    }
                } else {
                    alert(data.message || '삭제에 실패했습니다.');
                }
            } catch (err) {
                console.error('Delete error:', err);
                alert('서버 통신 에러가 발생하여 삭제에 실패했습니다.');
            }
        }

        // 모바일 사이드바 토글 스크립트
        const btnToggleMenu = document.getElementById('btnToggleMenu');
        const consoleSidebar = document.getElementById('consoleSidebar');
        const sidebarBackdrop = document.getElementById('sidebarBackdrop');

        if (btnToggleMenu && consoleSidebar && sidebarBackdrop) {
            const toggleSidebar = () => {
                consoleSidebar.classList.toggle('open');
                sidebarBackdrop.classList.toggle('open');
            };

            btnToggleMenu.addEventListener('click', toggleSidebar);
            sidebarBackdrop.addEventListener('click', toggleSidebar);
        }
    </script>
</body>
</html>
