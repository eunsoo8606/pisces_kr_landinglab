<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
    <link rel="icon" href="/favicon.webp?v=2" type="image/png">
    <!-- CKEditor 5 Classic CDN -->
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/translations/ko.js"></script>
    <style>
        body {
            background-color: #f8fafc;
            color: #334155;
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        .dashboard-layout {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        /* 1. 좌측 고정 사이드바 */
        .console-sidebar {
            width: 270px;
            background: #ffffff;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 100;
            box-sizing: border-box;
            box-shadow: 4px 0 20px rgba(15, 23, 42, 0.02);
            transition: transform 0.3s ease;
        }

        .sidebar-logo {
            padding: 28px 24px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
        }

        .sidebar-logo img {
            height: 38px;
            width: auto;
            filter: none;
        }

        .sidebar-logo span {
            color: #0284c7;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            border: 1px solid rgba(2, 132, 199, 0.25);
            padding: 2px 6px;
            border-radius: 4px;
            background-color: rgba(2, 132, 199, 0.05);
            letter-spacing: 0.5px;
        }

        .sidebar-menu {
            flex: 1;
            padding: 30px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            overflow-y: auto;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #475569;
            text-decoration: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            transition: all 0.25s ease;
            cursor: pointer;
            border: 1px solid transparent;
            box-sizing: border-box;
        }

        .menu-item svg {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            color: #64748b;
            transition: transform 0.2s ease;
        }

        .menu-item:hover {
            color: #0284c7;
            background: #f8fafc;
        }

        .menu-item:hover svg {
            transform: translateX(2px);
            color: #0284c7;
        }

        .menu-item.active {
            color: #0284c7;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        .menu-item.active svg {
            color: #0284c7;
        }

        .menu-item.sub-item {
            font-size: 13px;
            padding: 8px 18px 8px 30px;
            color: #64748b;
        }
        
        .menu-item.sub-item.active {
            color: #0369a1;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        /* 2. 우측 메인 콘텐츠 영역 */
        .console-main {
            margin-left: 270px;
            flex: 1;
            padding: 40px 50px;
            box-sizing: border-box;
            min-width: 0;
            transition: margin-left 0.3s ease;
        }

        /* 모바일 햄버거 헤더 */
        .mobile-header {
            display: none;
            justify-content: space-between;
            align-items: center;
            background: #ffffff;
            padding: 15px 20px;
            border-bottom: 1px solid #e2e8f0;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .mobile-menu-btn {
            background: none;
            border: none;
            color: #0f172a;
            cursor: pointer;
            padding: 5px;
        }

        .mobile-menu-btn svg {
            width: 24px;
            height: 24px;
        }

        /* 상단 타이틀 바 */
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 20px;
        }

        .main-header-title h2 {
            font-size: 26px;
            font-weight: 800;
            margin: 0;
            color: #0f172a;
            letter-spacing: -0.5px;
        }

        .main-header-title p {
            font-size: 13px;
            color: #64748b;
            margin: 6px 0 0 0;
        }

        /* 폼 카드 컨테이너 */
        .form-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 24px;
            padding: 35px;
            box-shadow: 0 10px 30px rgba(15, 23, 42, 0.04);
            margin-bottom: 30px;
            max-width: 900px;
        }

        .form-title {
            font-size: 18px;
            font-weight: 800;
            margin-top: 0;
            margin-bottom: 25px;
            border-left: 4px solid #0284c7;
            padding-left: 12px;
            color: #0f172a;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
            margin-bottom: 24px;
        }

        .form-row {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
            margin-bottom: 24px;
        }

        .form-label {
            font-size: 13px;
            color: #475569;
            font-weight: 700;
        }

        .form-control {
            background: #ffffff;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            color: #0f172a;
            padding: 12px 16px;
            font-size: 14px;
            font-family: inherit;
            outline: none;
            transition: all 0.3s ease;
            box-sizing: border-box;
            width: 100%;
        }

        .form-control:focus {
            border-color: #0284c7;
            box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.1);
        }

        .form-control:disabled, .form-control[readonly] {
            background: #f1f5f9;
            color: #64748b;
            border-color: #e2e8f0;
            cursor: not-allowed;
        }

        .checkbox-group {
            display: flex;
            align-items: center;
            gap: 10px;
            cursor: pointer;
            user-select: none;
        }

        .checkbox-group input {
            cursor: pointer;
            width: 18px;
            height: 18px;
            accent-color: #0284c7;
        }

        .radio-group {
            display: flex;
            gap: 20px;
            margin-top: 5px;
        }

        .radio-item {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
        }

        .radio-item input {
            width: 16px;
            height: 16px;
            accent-color: #0284c7;
            cursor: pointer;
        }

        /* 상세 내용용 뷰포트 (고객 원문 텍스트박스) */
        .content-view-box {
            background: #f8fafc;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            padding: 18px;
            font-size: 14px;
            line-height: 1.6;
            color: #334155;
            white-space: pre-wrap;
            word-break: break-all;
            min-height: 120px;
        }

        /* 하단 액션 버튼바 */
        .btn-bar {
            display: flex;
            gap: 15px;
            margin-top: 35px;
            border-top: 1px solid #e2e8f0;
            padding-top: 25px;
        }

        .btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            padding: 12px 28px;
            border-radius: 10px;
            font-weight: 800;
            font-size: 14px;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
            text-decoration: none;
            box-sizing: border-box;
        }

        .btn-primary {
            background: #0284c7;
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(2, 132, 199, 0.15);
        }

        .btn-primary:hover {
            background: #0369a1;
            transform: translateY(-2px);
            box-shadow: 0 6px 16px rgba(2, 132, 199, 0.25);
        }

        .btn-secondary {
            background: #ffffff;
            color: #475569;
            border: 1px solid #cbd5e1;
        }

        .btn-secondary:hover {
            background: #f8fafc;
            color: #0f172a;
        }

        /* 모바일 네비게이션용 백드롭 */
        .sidebar-backdrop {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(15, 23, 42, 0.3);
            backdrop-filter: blur(4px);
            -webkit-backdrop-filter: blur(4px);
            z-index: 98;
        }

        /* 모바일 반응형 미디어 쿼리 */
        @media (max-width: 992px) {
            .console-sidebar {
                transform: translateX(-100%);
            }
            
            .console-sidebar.open {
                transform: translateX(0);
            }
            
            .console-main {
                margin-left: 0;
                padding: 30px 20px;
            }
            
            .mobile-header {
                display: flex;
            }
            
            .main-header {
                display: none;
            }

            .sidebar-backdrop.open {
                display: block;
            }
        }

        @media (max-width: 768px) {
            .console-main {
                padding: 24px 16px;
            }

            .form-card {
                padding: 20px 15px;
                border-radius: 16px;
            }

            .form-row {
                grid-template-columns: 1fr;
                gap: 15px;
                margin-bottom: 15px;
            }

            .form-group {
                margin-bottom: 18px;
            }

            .btn-bar {
                flex-direction: column-reverse;
                gap: 10px;
                margin-top: 25px;
                padding-top: 20px;
            }

            .btn {
                width: 100%;
                box-sizing: border-box;
                padding: 14px 20px;
            }

            /* 라디오 그룹 정렬 조율 */
            .radio-group {
                flex-direction: column;
                gap: 12px;
            }

            /* CKEditor 모바일 크기 안정화 */
            .ck-editor__editable_inline {
                min-height: 220px;
                padding: 10px 15px !important;
            }
        }

        /* CKEditor Custom Styling */
        .ck-editor__editable_inline {
            min-height: 300px;
            border-bottom-left-radius: 10px !important;
            border-bottom-right-radius: 10px !important;
            background-color: #ffffff !important;
            color: #0f172a !important;
            padding: 15px 20px !important;
        }
        .ck-editor__top {
            border-top-left-radius: 10px !important;
            border-top-right-radius: 10px !important;
        }
        .ck-toolbar {
            border-top-left-radius: 10px !important;
            border-top-right-radius: 10px !important;
            background: #f8fafc !important;
            border-color: #cbd5e1 !important;
        }
        .ck.ck-editor__main>.ck-editor__editable {
            border-color: #cbd5e1 !important;
        }
        .ck.ck-editor__main>.ck-editor__editable:focus,
        .ck.ck-editor__main>.ck-editor__editable.ck-focused {
            border-color: #0284c7 !important;
            box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.1) !important;
            outline: none !important;
        }
    </style>
</head>
<body>
    <!-- 모바일 전용 헤더 -->
    <div class="mobile-header">
        <div style="display: flex; align-items: center; gap: 10px;">
            <button class="mobile-menu-btn" id="btnToggleMenu" aria-label="메뉴 열기">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <img src="/images/logo.webp" alt="물고기자리" style="height: 28px; width: auto;">
        </div>
        <span style="color: #0284c7; font-size: 11px; font-weight: bold; border: 1px solid rgba(2, 132, 199, 0.25); padding: 2px 6px; border-radius: 4px; background-color: rgba(2, 132, 199, 0.05);">console</span>
    </div>

    <!-- 모바일 사이드바 백드롭 -->
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <div class="dashboard-layout">
        <!-- 좌측 고정 사이드바 -->
        <div class="console-sidebar" id="consoleSidebar">
            <div class="sidebar-logo">
                <img src="/images/logo.webp" alt="물고기자리 로고">
                <span>console</span>
            </div>
            
            <div class="sidebar-menu">
                <!-- 1. 대쉬보드 -->
                <a href="/console/dashboard" class="menu-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="9"></rect>
                        <rect x="14" y="3" width="7" height="5"></rect>
                        <rect x="14" y="12" width="7" height="9"></rect>
                        <rect x="3" y="16" width="7" height="5"></rect>
                    </svg>
                    <span>대쉬보드</span>
                </a>

                <!-- 3. 게시판 관리 (서브메뉴 분리) -->
                <div class="menu-group" style="display: flex; flex-direction: column; gap: 4px; margin-top: 10px;">
                    <div class="menu-group-title" style="padding: 5px 20px; font-size: 11px; font-weight: bold; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;">게시판 관리</div>
                    <a href="/console/board/notice" class="menu-item sub-item <%= category === 'notice' ? 'active' : '' %>">
                        <span>- 공지사항 관리</span>
                    </a>
                    <a href="/console/board/faq" class="menu-item sub-item <%= category === 'faq' ? 'active' : '' %>">
                        <span>- FAQ 관리</span>
                    </a>
                    <a href="/console/board/voice" class="menu-item sub-item <%= category === 'voice' ? 'active' : '' %>">
                        <span>- 고객의 소리 관리</span>
                    </a>
                    <a href="/console/board/inquiry" class="menu-item sub-item <%= category === 'inquiry' ? 'active' : '' %>">
                        <span>- 문의게시판 관리</span>
                    </a>
                </div>

                <!-- 4. 메뉴(음식) 관리 -->
                <a href="/console/menu" class="menu-item <%= (typeof activeMenu !== 'undefined' && activeMenu === 'menu') ? 'active' : '' %>" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                        <path d="M2 12h20"></path>
                    </svg>
                    <span>메뉴(음식) 관리</span>
                </a>

                <!-- 5. 팝업관리 -->
                <a href="/console/popup" class="menu-item <%= (typeof activeMenu !== 'undefined' && activeMenu === 'popup') ? 'active' : '' %>" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="3" x2="9" y2="21"></line>
                        <line x1="17" y1="9" x2="21" y2="9"></line>
                        <line x1="17" y1="15" x2="21" y2="15"></line>
                    </svg>
                    <span>팝업관리</span>
                </a>
            </div>
        </div>

        <!-- 우측 메인 콘텐츠 영역 -->
        <div class="console-main">
            <!-- 메인 헤더 요약 정보 -->
            <div class="main-header">
                <div class="main-header-title">
                    <h2>게시글 작성 및 편집</h2>
                    <p>공지사항/FAQ 등록 및 수정, 고객문의(고객의소리, 가맹문의)에 대한 답변을 관리합니다.</p>
                </div>
            </div>

            <!-- 편집 카드 폼 -->
            <div class="form-card">
                <% 
                    const categoryTitles = {
                        'notice': '공지사항',
                        'faq': '자주 묻는 질문 (FAQ)',
                        'voice': '고객의 소리',
                        'inquiry': '문의게시판'
                    };
                %>
                <div class="form-title">
                    <%= categoryTitles[category] || '게시판' %> 
                    <%= action === 'write' ? '신규 등록' : '내용 확인 및 답변/수정' %>
                </div>

                <form id="boardForm" onsubmit="handleSubmit(event)">
                    <!-- 기본 메타 정보 숨김 처리 -->
                    <input type="hidden" id="boardCategory" name="category" value="<%= category %>">
                    <input type="hidden" id="actionType" value="<%= action %>">
                    <% if (board) { %>
                        <input type="hidden" id="boardId" value="<%= board.id %>">
                    <% } %>

                    <!-- 1. 공지사항 및 FAQ 편집 폼 -->
                    <% if (category === 'notice' || category === 'faq') { %>
                        <div class="form-group">
                            <label for="title" class="form-label">
                                <%= category === 'notice' ? '공지 제목' : 'FAQ 질문' %>
                            </label>
                            <input type="text" id="title" class="form-control" placeholder="제목을 입력하세요." value="<%= board ? board.title : '' %>" required>
                        </div>

                        <div class="form-group">
                            <label for="content" class="form-label">
                                <%= category === 'notice' ? '공지 내용' : 'FAQ 답변' %>
                            </label>
                            <textarea id="content" class="form-control" style="height: 300px; resize: vertical;" placeholder="내용을 입력하세요." required><%= board ? board.content : '' %></textarea>
                        </div>

                        <% if (category === 'notice') { %>
                            <div class="form-group" style="flex-direction: row; align-items: center; margin-top: 10px;">
                                <label class="checkbox-group">
                                    <input type="checkbox" id="is_pinned" name="is_pinned" value="1" <%= board && board.is_pinned === 1 ? 'checked' : '' %>>
                                    <span class="form-label" style="margin-bottom: 0; cursor: pointer;">이 공지글을 게시판 최상단에 고정합니다. (필독 공지)</span>
                                </label>
                            </div>
                        <% } %>
                    
                    <!-- 2. 고객의 소리 및 가맹문의 확인 및 답변 폼 -->
                    <% } else if (category === 'voice' || category === 'inquiry') { %>
                        <div class="form-row">
                            <div class="form-group">
                                <label class="form-label">작성자 성함</label>
                                <input type="text" class="form-control" value="<%= board.author_name %>" readonly>
                            </div>
                            <div class="form-group">
                                <label class="form-label">연락처</label>
                                <input type="text" class="form-control" value="<%= board.author_phone %>" readonly>
                            </div>
                        </div>

                        <% if (category === 'inquiry') { %>
                            <div class="form-row">
                                <div class="form-group">
                                    <label class="form-label">문의 분류</label>
                                    <% 
                                        const inquiryTypeMap = {
                                            'franchise': '신규 가맹/창업 상담 문의',
                                            'location': '매장 개설/상권 분석 문의',
                                            'alliance': '비즈니스 제휴/납품 문의',
                                            'other': '기타 문의사항'
                                        };
                                    %>
                                    <input type="text" class="form-control" value="<%= inquiryTypeMap[board.inquiry_type] || '기타' %>" readonly>
                                </div>
                                <div class="form-group">
                                    <label class="form-label">이메일 주소</label>
                                    <input type="text" class="form-control" value="<%= board.author_email || '등록 없음' %>" readonly>
                                </div>
                            </div>
                        <% } %>

                        <div class="form-group">
                            <label class="form-label">접수된 문의 제목</label>
                            <input type="text" class="form-control" value="<%= board.title %>" readonly>
                        </div>

                        <div class="form-group">
                            <label class="form-label">접수된 내용 원문</label>
                            <div class="content-view-box"><%= board.content %></div>
                        </div>

                        <div style="border-top: 1.5px dashed #e2e8f0; margin: 35px 0 30px 0; padding-top: 20px;">
                            <div class="form-title" style="border-left-color: #10b981;">관리자 답변 처리</div>
                        </div>

                        <div class="form-group">
                            <label for="reply_content" class="form-label">답변 내용</label>
                            <textarea id="reply_content" class="form-control" style="height: 180px; resize: vertical;" placeholder="답변을 작성해 주세요. (고객에게는 목록의 상태 배지로 피드백이 표시됩니다.)" required><%= board.reply_content || '' %></textarea>
                        </div>

                        <div class="form-group">
                            <label class="form-label">답변 처리 상태</label>
                            <div class="radio-group">
                                <label class="radio-item">
                                    <input type="radio" name="status" value="pending" <%= board.status === 'pending' ? 'checked' : '' %>>
                                    <span class="form-label">답변 대기 (접수완료)</span>
                                </label>
                                <label class="radio-item">
                                    <input type="radio" name="status" value="complete" <%= board.status === 'complete' ? 'checked' : '' %>>
                                    <span class="form-label" style="color: #10b981;">답변 완료</span>
                                </label>
                            </div>
                        </div>
                    <% } %>

                    <!-- 하단 버튼 바 -->
                    <div class="btn-bar">
                        <a href="/console/board/<%= category %>" class="btn btn-secondary">뒤로가기</a>
                        <button type="submit" class="btn btn-primary">
                            <%= (category === 'voice' || category === 'inquiry') ? '답변 저장하기' : '저장하기' %>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        let contentEditor;

        // DOM 로드 시 에디터 초기화
        document.addEventListener('DOMContentLoaded', () => {
            const contentEl = document.querySelector('#content');
            if (contentEl) {
                ClassicEditor
                    .create(contentEl, {
                        language: 'ko',
                        toolbar: [
                            'heading', '|',
                            'bold', 'italic', 'link', 'bulletedList', 'numberedList', 'blockQuote', '|',
                            'undo', 'redo'
                        ]
                    })
                    .then(editor => {
                        contentEditor = editor;
                    })
                    .catch(error => {
                        console.error('CKEditor 초기화 실패:', error);
                    });
            }
        });

        // 비동기 폼 저장 처리
        async function handleSubmit(e) {
            e.preventDefault();

            const category = document.getElementById('boardCategory').value;
            const actionType = document.getElementById('actionType').value;
            
            let url = '/api/board';
            let method = 'POST';
            
            const payload = {
                category
            };

            // 1. 공지사항/FAQ인 경우
            if (category === 'notice' || category === 'faq') {
                payload.title = document.getElementById('title').value;
                // 에디터 데이터 우선 가져오기, 없을 시 textarea 백업
                payload.content = contentEditor ? contentEditor.getData() : document.getElementById('content').value;
                
                const pinCheck = document.getElementById('is_pinned');
                if (pinCheck) {
                    payload.is_pinned = pinCheck.checked ? 1 : 0;
                }

                if (actionType === 'edit') {
                    const id = document.getElementById('boardId').value;
                    url = `/api/board/${id}`;
                    method = 'PUT';
                }
            }
            // 2. 고객의소리/문의사항 답변인 경우
            else if (category === 'voice' || category === 'inquiry') {
                const id = document.getElementById('boardId').value;
                url = `/api/board/reply/${id}`;
                method = 'POST';
                payload.reply_content = document.getElementById('reply_content').value;
                payload.status = document.querySelector('input[name="status"]:checked').value;
            }

            try {
                const response = await fetch(url, {
                    method: method,
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify(payload)
                });

                const data = await response.json();
                if (data.success) {
                    alert(data.message || '성공적으로 저장되었습니다.');
                    location.href = `/console/board/${category}`;
                } else {
                    alert(data.message || '저장에 실패하였습니다.');
                }
            } catch (err) {
                console.error('Submit error:', err);
                alert('서버 전송 중 네트워크 에러가 발생하였습니다.');
            }
        }

        // 모바일 사이드바 토글 스크립트
        const btnToggleMenu = document.getElementById('btnToggleMenu');
        const consoleSidebar = document.getElementById('consoleSidebar');
        const sidebarBackdrop = document.getElementById('sidebarBackdrop');

        if (btnToggleMenu && consoleSidebar && sidebarBackdrop) {
            const toggleSidebar = () => {
                consoleSidebar.classList.toggle('open');
                sidebarBackdrop.classList.toggle('open');
            };

            btnToggleMenu.addEventListener('click', toggleSidebar);
            sidebarBackdrop.addEventListener('click', toggleSidebar);
        }
    </script>
</body>
</html>
