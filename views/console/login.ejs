<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>관리자 로그인 | 물고기자리 - 프리미엄 숙성회</title>
    <link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
    <link rel="icon" href="/favicon.png?v=2" type="image/png">
    <style>
        /* 럭셔리 다크 로그인 배경 */
        body {
            margin: 0;
            padding: 0;
            background-color: #03080f;
            font-family: 'Pretendard', sans-serif;
        }
        
        .admin-login-wrapper {
            min-height: 100vh;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(0, 242, 254, 0.05) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(0, 86, 179, 0.08) 0%, transparent 45%);
            padding: 20px;
            box-sizing: border-box;
        }

        /* 글래스모피즘 로그인 카드 */
        .login-card {
            width: 100%;
            max-width: 440px;
            background: rgba(11, 26, 48, 0.35);
            border: 1.5px solid rgba(0, 242, 254, 0.12);
            border-radius: 24px;
            padding: 50px 40px;
            box-sizing: border-box;
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            box-shadow: 
                0 15px 35px rgba(0, 0, 0, 0.5),
                0 0 50px rgba(0, 242, 254, 0.03);
            text-align: center;
            transform: translateY(20px);
            opacity: 0;
            animation: cardFadeIn 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes cardFadeIn {
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        /* 로고 영역 */
        .login-logo {
            margin-bottom: 35px;
        }

        .login-logo h2 {
            font-size: 28px;
            font-weight: 800;
            color: #ffffff;
            letter-spacing: -0.5px;
            margin: 0;
        }

        .login-logo h2 span {
            color: #00f2fe;
            text-shadow: 0 0 10px rgba(0, 242, 254, 0.4);
        }

        .login-logo p {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.4);
            margin-top: 8px;
            letter-spacing: 0.15em;
            text-transform: uppercase;
        }

        /* 입력 폼 */
        .login-form-group {
            position: relative;
            margin-bottom: 24px;
            text-align: left;
        }

        .login-form-group label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: rgba(255, 255, 255, 0.65);
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .login-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .login-input-wrap input {
            width: 100%;
            height: 52px;
            background: rgba(255, 255, 255, 0.03);
            border: 1px solid rgba(255, 255, 255, 0.1);
            border-radius: 12px;
            padding: 0 20px;
            color: #ffffff;
            font-size: 15px;
            font-weight: 500;
            box-sizing: border-box;
            transition: all 0.3s ease;
            outline: none;
        }

        .login-input-wrap input:focus {
            background: rgba(0, 242, 254, 0.02);
            border-color: rgba(0, 242, 254, 0.5);
            box-shadow: 0 0 15px rgba(0, 242, 254, 0.15);
        }

        /* 로그인 전송 버튼 */
        .btn-login-submit {
            width: 100%;
            height: 54px;
            background: linear-gradient(90deg, #00f2fe 0%, #00a8cc 100%);
            color: #00182e;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
            box-shadow: 0 10px 20px rgba(0, 242, 254, 0.15);
            margin-top: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }

        .btn-login-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 15px 30px rgba(0, 242, 254, 0.3);
        }

        .btn-login-submit:active {
            transform: translateY(0);
        }

        /* 돌아가기 링크 */
        .back-to-home {
            display: inline-block;
            margin-top: 30px;
            font-size: 13px;
            color: rgba(255, 255, 255, 0.45);
            text-decoration: none;
            transition: color 0.3s ease;
        }

        .back-to-home:hover {
            color: #00f2fe;
        }
    </style>
</head>
<body>
    <div class="admin-login-wrapper">
        <div class="login-card">
            <div class="login-logo">
                <h2>물고기자리 <span>관리자</span></h2>
                <p>Admin Console</p>
            </div>
            
            <form action="/console/login" method="POST" id="loginForm">
                <!-- 아이디 입력 -->
                <div class="login-form-group">
                    <label for="username">관리자 아이디</label>
                    <div class="login-input-wrap">
                        <input type="text" id="username" name="username" placeholder="아이디를 입력하세요" required autocomplete="off">
                    </div>
                </div>
                
                <!-- 비밀번호 입력 -->
                <div class="login-form-group">
                    <label for="password">비밀번호</label>
                    <div class="login-input-wrap">
                        <input type="password" id="password" name="password" placeholder="비밀번호를 입력하세요" required>
                    </div>
                </div>
                
                <!-- 제출 버튼 -->
                <button type="submit" class="btn-login-submit">
                    <span>로그인하기</span>
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </button>
            </form>
            
            <a href="/" class="back-to-home">← 메인 페이지로 돌아가기</a>
        </div>
    </div>
</body>
</html>
