<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>관리자 로그인 | 물고기자리 - 프리미엄 숙성회</title>
    <link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
    <link rel="icon" href="/favicon.webp?v=2" type="image/png">
    <style>
        /* 깔끔하고 프리미엄한 라이트 로그인 테마 */
        body {
            margin: 0;
            padding: 0;
            background-color: #f8fafc;
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
            color: #0f172a;
        }
        
        .admin-login-wrapper {
            min-height: 100vh;
            width: 100%;
            display: flex;
            justify-content: center;
            align-items: center;
            background-image: 
                radial-gradient(circle at 10% 20%, rgba(2, 132, 199, 0.03) 0%, transparent 40%),
                radial-gradient(circle at 90% 80%, rgba(2, 132, 199, 0.05) 0%, transparent 45%);
            padding: 20px;
            box-sizing: border-box;
        }

        /* 미니멀한 프리미엄 화이트 카드 */
        .login-card {
            width: 100%;
            max-width: 440px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 20px;
            padding: 50px 40px;
            box-sizing: border-box;
            box-shadow: 
                0 10px 25px rgba(15, 23, 42, 0.05),
                0 1px 3px rgba(0, 0, 0, 0.02);
            text-align: center;
            transform: translateY(15px);
            opacity: 0;
            animation: cardFadeIn 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        @keyframes cardFadeIn {
            to {
                transform: translateY(0);
                opacity: 1;
            }
        }

        /* 로고 영역 */
        .login-logo {
            margin-bottom: 35px;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }

        .login-logo img {
            height: 38px;
            width: auto;
            margin-bottom: 5px;
        }

        .login-logo h2 {
            font-size: 24px;
            font-weight: 800;
            color: #0f172a;
            letter-spacing: -0.5px;
            margin: 0;
        }

        .login-logo h2 span {
            color: #0284c7;
        }

        .login-logo p {
            font-size: 11px;
            color: #64748b;
            margin: 0;
            letter-spacing: 0.15em;
            text-transform: uppercase;
            font-weight: 700;
        }

        /* 입력 폼 */
        .login-form-group {
            margin-bottom: 24px;
            text-align: left;
        }

        .login-form-group label {
            display: block;
            font-size: 13px;
            font-weight: 700;
            color: #475569;
            margin-bottom: 8px;
            letter-spacing: 0.5px;
        }

        .login-input-wrap {
            position: relative;
            display: flex;
            align-items: center;
        }

        .login-input-wrap input {
            width: 100%;
            height: 50px;
            background: #ffffff;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            padding: 0 16px;
            color: #0f172a;
            font-size: 14px;
            font-weight: 500;
            box-sizing: border-box;
            transition: all 0.3s ease;
            outline: none;
        }

        .login-input-wrap input:focus {
            border-color: #0284c7;
            box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.12);
        }

        /* 로그인 전송 버튼 (포인트 기본색 적용) */
        .btn-login-submit {
            width: 100%;
            height: 50px;
            background: #0284c7;
            color: #ffffff;
            border: none;
            border-radius: 10px;
            font-size: 15px;
            font-weight: 800;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.165, 0.84, 0.44, 1);
            box-shadow: 0 4px 12px rgba(2, 132, 199, 0.15);
            margin-top: 15px;
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
        }

        .btn-login-submit:hover {
            background: #0369a1;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(2, 132, 199, 0.25);
        }

        .btn-login-submit:active {
            transform: translateY(0);
        }

        /* 돌아가기 링크 */
        .back-to-home {
            display: inline-block;
            margin-top: 30px;
            font-size: 13px;
            color: #64748b;
            text-decoration: none;
            transition: color 0.3s ease;
            font-weight: 600;
        }

        .back-to-home:hover {
            color: #0284c7;
        }
    </style>
</head>
<body>
    <div class="admin-login-wrapper">
        <div class="login-card">
            <div class="login-logo">
                <img src="/images/logo.webp" alt="물고기자리 로고" style="filter: none;">
                <h2>물고기자리 <span>관리자</span></h2>
                <p>Admin Console</p>
            </div>
            
            <form action="/console/login" method="POST" id="loginForm">
                <!-- 아이디 입력 -->
                <div class="login-form-group">
                    <label for="username">관리자 아이디</label>
                    <div class="login-input-wrap">
                        <input type="text" id="username" name="username" placeholder="아이디를 입력하세요" required autocomplete="off">
                    </div>
                </div>
                
                <!-- 비밀번호 입력 -->
                <div class="login-form-group">
                    <label for="password">비밀번호</label>
                    <div class="login-input-wrap">
                        <input type="password" id="password" name="password" placeholder="비밀번호를 입력하세요" required>
                    </div>
                </div>
                
                <!-- 제출 버튼 -->
                <button type="submit" class="btn-login-submit">
                    <span>로그인하기</span>
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                    </svg>
                </button>
            </form>
            
            <a href="/" class="back-to-home">← 메인 페이지로 돌아가기</a>
        </div>
    </div>
</body>
</html>
