<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
    <link rel="icon" href="/favicon.webp?v=2" type="image/png">
    <style>
        /* 프리미엄 라이트 테마 */
        body {
            background-color: #f8fafc;
            color: #334155;
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        .dashboard-layout {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        /* 1. 좌측 고정 사이드바 */
        .console-sidebar {
            width: 270px;
            background: #ffffff;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 100;
            box-sizing: border-box;
            box-shadow: 4px 0 20px rgba(15, 23, 42, 0.02);
            transition: transform 0.3s ease;
        }

        .sidebar-logo {
            padding: 28px 24px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
        }

        .sidebar-logo img {
            height: 38px;
            width: auto;
        }

        .sidebar-logo span {
            color: #0284c7;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            border: 1px solid rgba(2, 132, 199, 0.25);
            padding: 2px 6px;
            border-radius: 4px;
            background-color: rgba(2, 132, 199, 0.05);
            letter-spacing: 0.5px;
        }

        .sidebar-menu {
            flex: 1;
            padding: 30px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            overflow-y: auto;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #475569;
            text-decoration: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            transition: all 0.25s ease;
            cursor: pointer;
            border: 1px solid transparent;
            box-sizing: border-box;
        }

        .menu-item svg {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            color: #64748b;
            transition: transform 0.2s ease;
        }

        .menu-item:hover {
            color: #0284c7;
            background: #f8fafc;
        }

        .menu-item:hover svg {
            transform: translateX(2px);
            color: #0284c7;
        }

        .menu-item.active {
            color: #0284c7;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        .menu-item.active svg {
            color: #0284c7;
        }

        .menu-item.sub-item {
            font-size: 13px;
            padding: 8px 18px 8px 30px;
            color: #64748b;
        }

        .menu-item.sub-item.active {
            color: #0369a1;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        /* 2. 우측 메인 콘텐츠 영역 */
        .console-main {
            margin-left: 270px;
            flex: 1;
            padding: 40px 50px;
            box-sizing: border-box;
            min-width: 0;
            transition: margin-left 0.3s ease;
        }

        /* 모바일 햄버거 헤더 */
        .mobile-header {
            display: none;
            justify-content: space-between;
            align-items: center;
            background: #ffffff;
            padding: 15px 20px;
            border-bottom: 1px solid #e2e8f0;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .mobile-menu-btn {
            background: none;
            border: none;
            color: #0f172a;
            cursor: pointer;
            padding: 5px;
        }

        .mobile-menu-btn svg {
            width: 24px;
            height: 24px;
        }

        /* 상단 타이틀 바 */
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 20px;
        }

        .main-header-title h2 {
            font-size: 26px;
            font-weight: 800;
            margin: 0;
            color: #0f172a;
            letter-spacing: -0.5px;
        }

        .main-header-title p {
            font-size: 13px;
            color: #64748b;
            margin: 6px 0 0 0;
        }

        .header-profile-wrap {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            padding: 8px 16px;
            border-radius: 12px;
        }

        .user-profile {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .user-name {
            font-size: 13px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }

        .user-role {
            font-size: 10px;
            color: #64748b;
            margin: 0;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 6px 12px;
            background: rgba(239, 68, 68, 0.06);
            border: 1px solid rgba(239, 68, 68, 0.15);
            color: #ef4444;
            font-size: 12px;
            font-weight: 700;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.25s ease;
        }

        .btn-logout:hover {
            background: #ef4444;
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.15);
        }

        /* 폼 입력 레이아웃 카드 */
        .form-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 35px;
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
            margin-bottom: 30px;
        }

        .form-group {
            margin-bottom: 24px;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-row-2 {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 20px;
        }

        .form-row-4 {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
        }

        .form-label {
            font-size: 14px;
            font-weight: 700;
            color: #334155;
            display: flex;
            align-items: center;
            gap: 6px;
        }

        .form-label span.required {
            color: #ef4444;
            font-size: 12px;
        }

        .form-control {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            font-size: 14px;
            color: #334155;
            background-color: #ffffff;
            outline: none;
            transition: all 0.2s ease;
            box-sizing: border-box;
        }

        .form-control:focus {
            border-color: #0284c7;
            box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.1);
        }

        .form-control::placeholder {
            color: #94a3b8;
        }

        /* 체크박스 / 라디오 커스텀 */
        .checkbox-container {
            display: flex;
            align-items: center;
            gap: 8px;
            cursor: pointer;
            user-select: none;
            font-size: 14px;
            font-weight: 600;
            color: #475569;
            padding: 10px 0;
        }

        .checkbox-container input {
            width: 18px;
            height: 18px;
            cursor: pointer;
            accent-color: #0284c7;
        }

        /* 이미지 미리보기 박스 */
        .image-preview-wrap {
            display: flex;
            gap: 20px;
            align-items: flex-start;
            margin-top: 5px;
        }

        .image-preview-box {
            width: 160px;
            height: 160px;
            border-radius: 12px;
            border: 1px dashed #cbd5e1;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
            background: #f8fafc;
            flex-shrink: 0;
        }

        .image-preview-box img {
            width: 100%;
            height: 100%;
            object-fit: contain;
            background-color: #f1f5f9;
        }

        .image-preview-info {
            font-size: 12px;
            color: #64748b;
            display: flex;
            flex-direction: column;
            gap: 4px;
            justify-content: center;
            min-height: 160px;
        }

        /* 버튼 바 */
        .form-actions {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 12px;
            border-top: 1px solid #e2e8f0;
            padding-top: 25px;
            margin-top: 10px;
        }

        .btn-cancel {
            padding: 12px 28px;
            background: #f1f5f9;
            border: 1px solid #cbd5e1;
            color: #475569;
            font-size: 14px;
            font-weight: 700;
            border-radius: 10px;
            text-decoration: none;
            transition: all 0.2s ease;
            text-align: center;
        }

        .btn-cancel:hover {
            background: #e2e8f0;
        }

        .btn-save {
            padding: 12px 32px;
            background: #0284c7;
            border: 1px solid #0284c7;
            color: #ffffff;
            font-size: 14px;
            font-weight: 700;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.25s ease;
        }

        .btn-save:hover {
            background: #0369a1;
            border-color: #0369a1;
            box-shadow: 0 4px 12px rgba(2, 132, 199, 0.15);
        }

        /* 모바일 반응형 미디어 쿼리 */
        @media (max-width: 992px) {
            .console-sidebar {
                transform: translateX(-100%);
            }
            
            .console-sidebar.open {
                transform: translateX(0);
                box-shadow: 10px 0 35px rgba(15, 23, 42, 0.1);
            }
            
            .console-main {
                margin-left: 0;
                padding: 30px 20px;
            }
            
            .mobile-header {
                display: flex;
            }
            
            .main-header {
                display: none;
            }
        }

        @media (max-width: 768px) {
            .console-main {
                padding: 24px 16px;
            }

            .form-card {
                padding: 20px 15px;
                border-radius: 12px;
            }

            .form-row-2 {
                grid-template-columns: 1fr;
                gap: 0;
            }

            .form-row-4 {
                grid-template-columns: 1fr 1fr;
                gap: 12px;
            }

            .form-group {
                margin-bottom: 16px;
            }

            /* 이미지 업로드 미리보기 박스 모바일 대응 */
            .image-preview-wrap {
                flex-direction: column;
                align-items: center;
                gap: 15px;
                text-align: center;
            }

            .image-preview-info {
                min-height: auto;
                align-items: center;
            }

            /* 하단 저장/취소 버튼 모바일 조율 */
            .form-actions {
                flex-direction: column-reverse;
                gap: 10px;
                padding-top: 20px;
                margin-top: 15px;
            }

            .btn-cancel, .btn-save {
                width: 100%;
                box-sizing: border-box;
                padding: 14px 20px;
            }
        }
    </style>
</head>
<body>
    <%
        // EJS 날짜 변환 헬퍼 함수
        function formatDatetimeLocal(dateStr) {
            if (!dateStr) return '';
            const d = new Date(dateStr);
            const yyyy = d.getFullYear();
            const mm = String(d.getMonth() + 1).padStart(2, '0');
            const dd = String(d.getDate()).padStart(2, '0');
            const hh = String(d.getHours()).padStart(2, '0');
            const min = String(d.getMinutes()).padStart(2, '0');
            return `${yyyy}-${mm}-${dd}T${hh}:${min}`;
        }
    %>

    <!-- 모바일 전용 헤더 -->
    <div class="mobile-header">
        <div style="display: flex; align-items: center; gap: 10px;">
            <button class="mobile-menu-btn" id="btnToggleMenu" aria-label="메뉴 열기">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <img src="/images/logo.webp" alt="물고기자리" style="height: 28px; width: auto;">
        </div>
        <span style="color: #0284c7; font-size: 11px; font-weight: bold; border: 1px solid rgba(2,132,199,0.3); padding: 1px 4px; border-radius: 4px; background: rgba(2,132,199,0.05);">console</span>
    </div>

    <!-- 모바일 사이드바 백드롭 -->
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <div class="dashboard-layout">
        <!-- 좌측 고정 사이드바 -->
        <div class="console-sidebar" id="consoleSidebar">
            <div class="sidebar-logo">
                <img src="/images/logo.webp" alt="물고기자리 로고">
                <span>console</span>
            </div>
            
            <div class="sidebar-menu">
                <!-- 1. 대쉬보드 -->
                <a href="/console/dashboard" class="menu-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="9"></rect>
                        <rect x="14" y="3" width="7" height="5"></rect>
                        <rect x="14" y="12" width="7" height="9"></rect>
                        <rect x="3" y="16" width="7" height="5"></rect>
                    </svg>
                    <span>대쉬보드</span>
                </a>

                <!-- 3. 게시판 관리 -->
                <div class="menu-group" style="display: flex; flex-direction: column; gap: 4px; margin-top: 10px;">
                    <div class="menu-group-title" style="padding: 5px 20px; font-size: 11px; font-weight: bold; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;">게시판 관리</div>
                    <a href="/console/board/notice" class="menu-item sub-item">
                        <span>- 공지사항 관리</span>
                    </a>
                    <a href="/console/board/faq" class="menu-item sub-item">
                        <span>- FAQ 관리</span>
                    </a>
                    <a href="/console/board/voice" class="menu-item sub-item">
                        <span>- 고객의 소리 관리</span>
                    </a>
                    <a href="/console/board/inquiry" class="menu-item sub-item">
                        <span>- 문의게시판 관리</span>
                    </a>
                </div>

                <!-- 4. 메뉴(음식) 관리 -->
                <a href="/console/menu" class="menu-item" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                        <path d="M2 12h20"></path>
                    </svg>
                    <span>메뉴(음식) 관리</span>
                </a>

                <!-- 5. 팝업관리 -->
                <a href="/console/popup" class="menu-item active" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="3" x2="9" y2="21"></line>
                        <line x1="17" y1="9" x2="21" y2="9"></line>
                        <line x1="17" y1="15" x2="21" y2="15"></line>
                    </svg>
                    <span>팝업관리</span>
                </a>
            </div>
        </div>

        <!-- 우측 메인 콘텐츠 영역 -->
        <div class="console-main">
            <!-- 메인 헤더 -->
            <div class="main-header">
                <div class="main-header-title">
                    <h2><%= action === 'write' ? '팝업 등록' : '팝업 수정' %></h2>
                    <p><%= action === 'write' ? '신규 공지/이벤트 팝업 정보와 이미지를 등록합니다.' : '기존 공지/이벤트 팝업 정보 및 이미지를 변경합니다.' %></p>
                </div>
                
                <div style="display: flex; align-items: center; gap: 20px;">
                    <div class="header-profile-wrap">
                        <div class="user-profile">
                            <span class="user-name"><%= adminUser.name %> 님</span>
                            <span class="user-role">최고관리자 (ID: <%= adminUser.username %>)</span>
                        </div>
                        <a href="/console/logout" class="btn-logout">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                <polyline points="16 17 21 12 16 7"></polyline>
                                <line x1="21" y1="12" x2="9" y2="12"></line>
                            </svg>
                            <span>로그아웃</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- 입력 폼 카드 -->
            <div class="form-card">
                <form id="popupForm" enctype="multipart/form-data" onsubmit="savePopup(event)">
                    <input type="hidden" id="image_url" name="image_url" value="<%= popupItem ? popupItem.image_url : '' %>">
                    
                    <!-- 팝업 제목 -->
                    <div class="form-group">
                        <label class="form-label" for="title">팝업 제목 <span class="required">*</span></label>
                        <input type="text" id="title" name="title" class="form-control" placeholder="예: [공지] 리뉴얼 기념 창업 이벤트안내" required value="<%= popupItem ? popupItem.title : '' %>">
                    </div>

                    <div class="form-row-2">
                        <!-- 링크 URL -->
                        <div class="form-group">
                            <label class="form-label" for="link_url">링크 이동 주소 (URL)</label>
                            <input type="text" id="link_url" name="link_url" class="form-control" placeholder="예: /#franchise 또는 외부 링크주소 (선택 사항)" value="<%= popupItem ? popupItem.link_url : '' %>">
                        </div>

                        <!-- 링크 타겟 -->
                        <div class="form-group">
                            <label class="form-label" for="target">링크 연결 타겟</label>
                            <select id="target" name="target" class="form-control">
                                <option value="_self" <%= (popupItem && popupItem.target === '_self') ? 'selected' : '' %>>현재 창 이동 (_self)</option>
                                <option value="_blank" <%= (popupItem && popupItem.target === '_blank') ? 'selected' : '' %>>새 창 열기 (_blank)</option>
                            </select>
                        </div>
                    </div>

                    <!-- 크기 및 위치 좌표 설정 -->
                    <div class="form-row-4">
                        <div class="form-group">
                            <label class="form-label" for="width">가로 크기 (px)</label>
                            <input type="number" id="width" name="width" class="form-control" placeholder="기본값: 400" value="<%= popupItem ? popupItem.width : '400' %>">
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="height">세로 크기 (px)</label>
                            <input type="number" id="height" name="height" class="form-control" placeholder="기본값: 500" value="<%= popupItem ? popupItem.height : '500' %>">
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="position_left">좌측 위치 (left px)</label>
                            <input type="number" id="position_left" name="position_left" class="form-control" placeholder="기본값: 50" value="<%= popupItem ? popupItem.position_left : '50' %>">
                        </div>
                        <div class="form-group">
                            <label class="form-label" for="position_top">상단 위치 (top px)</label>
                            <input type="number" id="position_top" name="position_top" class="form-control" placeholder="기본값: 50" value="<%= popupItem ? popupItem.position_top : '50' %>">
                        </div>
                    </div>

                    <div class="form-row-2">
                        <!-- 노출 시작 일시 -->
                        <div class="form-group">
                            <label class="form-label" for="start_date">노출 시작 일시 <span class="required">*</span></label>
                            <input type="datetime-local" id="start_date" name="start_date" class="form-control" required value="<%= popupItem ? formatDatetimeLocal(popupItem.start_date) : '' %>">
                        </div>

                        <!-- 노출 종료 일시 -->
                        <div class="form-group">
                            <label class="form-label" for="end_date">노출 종료 일시 <span class="required">*</span></label>
                            <input type="datetime-local" id="end_date" name="end_date" class="form-control" required value="<%= popupItem ? formatDatetimeLocal(popupItem.end_date) : '' %>">
                        </div>
                    </div>

                    <!-- 이미지 업로드 -->
                    <div class="form-group">
                        <label class="form-label">팝업 배너 이미지 등록 <span class="required">*</span></label>
                        
                        <div style="background: #f8fafc; border: 1px solid #cbd5e1; border-radius: 10px; padding: 18px;">
                            <input type="file" id="image_file" name="image_file" accept="image/*" class="form-control" style="padding: 8px;" <%= action === 'write' ? 'required' : '' %>>
                        </div>
                        
                        <!-- 미리보기 -->
                        <div class="image-preview-wrap" style="margin-top: 15px;">
                            <div class="image-preview-box">
                                <img id="previewImg" src="<%= popupItem ? popupItem.image_url : '/images/logo.webp' %>" onerror="this.src='/images/logo.webp'">
                            </div>
                            <div class="image-preview-info">
                                <strong>[실시간 이미지 썸네일 미리보기]</strong>
                                <span id="previewStatus" style="color: #0284c7; font-weight: bold;">
                                    <%= popupItem ? '기존 등록된 팝업 이미지를 로드했습니다.' : '업로드할 이미지 파일을 선택해 주세요.' %>
                                </span>
                                <span>* 권장 해상도: 작성하신 가로/세로 크기에 비례하는 배너 규격</span>
                                <span>* 수정 시 이미지를 첨부하지 않으면 기존 이미지가 그대로 유지됩니다.</span>
                            </div>
                        </div>
                    </div>

                    <!-- 활성화 여부 및 액션 -->
                    <div class="form-row-2" style="margin-top: 10px;">
                        <div class="form-group" style="justify-content: center;">
                            <label class="checkbox-container">
                                <input type="checkbox" id="is_active" name="is_active" value="1" <%= (!popupItem || popupItem.is_active === 1) ? 'checked' : '' %>>
                                노출 활성화 (즉시 노출 조건 적용)
                            </label>
                        </div>
                    </div>

                    <div class="form-actions">
                        <a href="/console/popup" class="btn-cancel">취소</a>
                        <button type="submit" class="btn-save">저장</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        const inputFile = document.getElementById('image_file');
        const previewImg = document.getElementById('previewImg');
        const previewStatus = document.getElementById('previewStatus');
        const imageUrlHidden = document.getElementById('image_url');
        
        let objectUrl = null;

        // 1. 파일 변경 시 실시간 미리보기 연동
        if (inputFile && previewImg) {
            inputFile.addEventListener('change', function() {
                const files = this.files;
                if (files && files.length > 0) {
                    const file = files[0];
                    if (objectUrl) {
                        URL.revokeObjectURL(objectUrl);
                    }
                    objectUrl = URL.createObjectURL(file);
                    previewImg.src = objectUrl;
                    previewStatus.textContent = `[업로드 대기] 파일명: ${file.name}`;
                    previewStatus.style.color = '#16a34a';
                } else {
                    resetToDefaultPreview();
                }
            });
        }

        function resetToDefaultPreview() {
            if (objectUrl) {
                URL.revokeObjectURL(objectUrl);
                objectUrl = null;
            }
            const existingPath = imageUrlHidden.value.trim();
            previewImg.src = existingPath ? existingPath : '/images/logo.webp';
            previewStatus.textContent = existingPath ? '기존 이미지로 복귀했습니다.' : '업로드할 이미지 파일을 선택해 주세요.';
            previewStatus.style.color = existingPath ? '#0284c7' : '#64748b';
        }

        // 2. 비동기 폼 데이터 저장
        async function savePopup(e) {
            e.preventDefault();

            const title = document.getElementById('title').value.trim();
            const link_url = document.getElementById('link_url').value.trim();
            const target = document.getElementById('target').value;
            const width = parseInt(document.getElementById('width').value, 10) || 400;
            const height = parseInt(document.getElementById('height').value, 10) || 500;
            const position_left = parseInt(document.getElementById('position_left').value, 10) || 50;
            const position_top = parseInt(document.getElementById('position_top').value, 10) || 50;
            const start_date = document.getElementById('start_date').value;
            const end_date = document.getElementById('end_date').value;
            const is_active = document.getElementById('is_active').checked ? 1 : 0;
            const image_url = imageUrlHidden.value.trim();
            const imageFile = inputFile.files[0];
            const action = '<%= action %>';

            if (!title || !start_date || !end_date) {
                alert('필수 입력 항목을 모두 작성해 주세요.');
                return;
            }

            if (action === 'write' && !imageFile) {
                alert('팝업 배너 이미지 파일을 첨부해 주세요.');
                return;
            }

            // 시작 날짜와 종료 날짜 논리 비교
            if (new Date(start_date) > new Date(end_date)) {
                alert('노출 시작일이 노출 종료일보다 늦을 수 없습니다.');
                return;
            }

            const formData = new FormData();
            formData.append('title', title);
            formData.append('link_url', link_url);
            formData.append('target', target);
            formData.append('width', width);
            formData.append('height', height);
            formData.append('position_left', position_left);
            formData.append('position_top', position_top);
            formData.append('start_date', start_date);
            formData.append('end_date', end_date);
            formData.append('is_active', is_active);
            formData.append('image_url', image_url);
            
            if (imageFile) {
                formData.append('image_file', imageFile);
            }

            const id = '<%= popupItem ? popupItem.id : "" %>';
            const url = action === 'write' ? '/api/popup' : `/api/popup/${id}`;
            const method = action === 'write' ? 'POST' : 'PUT';

            try {
                const response = await fetch(url, {
                    method: method,
                    body: formData
                });

                const data = await response.json();
                if (data.success) {
                    alert(data.message || '성공적으로 저장되었습니다.');
                    location.href = '/console/popup';
                } else {
                    alert(data.message || '저장에 실패했습니다.');
                }
            } catch (err) {
                console.error('Save error:', err);
                alert('서버 통신 에러가 발생하여 저장하지 못했습니다.');
            }
        }

        // 모바일 사이드바 토글 스크립트
        const btnToggleMenu = document.getElementById('btnToggleMenu');
        const consoleSidebar = document.getElementById('consoleSidebar');
        const sidebarBackdrop = document.getElementById('sidebarBackdrop');

        if (btnToggleMenu && consoleSidebar && sidebarBackdrop) {
            const toggleSidebar = () => {
                consoleSidebar.classList.toggle('open');
                sidebarBackdrop.classList.toggle('open');
            };

            btnToggleMenu.addEventListener('click', toggleSidebar);
            sidebarBackdrop.addEventListener('click', toggleSidebar);
        }
    </script>
</body>
</html>
