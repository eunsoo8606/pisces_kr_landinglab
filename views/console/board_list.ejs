<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
    <link rel="icon" href="/favicon.webp?v=2" type="image/png">
    <style>
        /* 프리미엄 라이트 테마 */
        body {
            background-color: #f8fafc;
            color: #334155;
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        .dashboard-layout {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        /* 1. 좌측 고정 사이드바 */
        .console-sidebar {
            width: 270px;
            background: #ffffff;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 100;
            box-sizing: border-box;
            box-shadow: 4px 0 20px rgba(15, 23, 42, 0.02);
            transition: transform 0.3s ease;
        }

        .sidebar-logo {
            padding: 28px 24px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
        }

        .sidebar-logo img {
            height: 38px;
            width: auto;
            filter: none;
        }

        .sidebar-logo span {
            color: #0284c7;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            border: 1px solid rgba(2, 132, 199, 0.25);
            padding: 2px 6px;
            border-radius: 4px;
            background-color: rgba(2, 132, 199, 0.05);
            letter-spacing: 0.5px;
        }

        .sidebar-menu {
            flex: 1;
            padding: 30px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            overflow-y: auto;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #475569;
            text-decoration: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            transition: all 0.25s ease;
            cursor: pointer;
            border: 1px solid transparent;
            box-sizing: border-box;
        }

        .menu-item svg {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            color: #64748b;
            transition: transform 0.2s ease;
        }

        .menu-item:hover {
            color: #0284c7;
            background: #f8fafc;
        }

        .menu-item:hover svg {
            transform: translateX(2px);
            color: #0284c7;
        }

        .menu-item.active {
            color: #0284c7;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        .menu-item.active svg {
            color: #0284c7;
        }

        .menu-item.sub-item {
            font-size: 13px;
            padding: 8px 18px 8px 30px;
            color: #64748b;
        }

        .menu-item.sub-item.active {
            color: #0369a1;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        /* 2. 우측 메인 콘텐츠 영역 */
        .console-main {
            margin-left: 270px;
            flex: 1;
            padding: 40px 50px;
            box-sizing: border-box;
            min-width: 0;
            transition: margin-left 0.3s ease;
        }

        /* 모바일 햄버거 헤더 */
        .mobile-header {
            display: none;
            justify-content: space-between;
            align-items: center;
            background: #ffffff;
            padding: 15px 20px;
            border-bottom: 1px solid #e2e8f0;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .mobile-menu-btn {
            background: none;
            border: none;
            color: #0f172a;
            cursor: pointer;
            padding: 5px;
        }

        .mobile-menu-btn svg {
            width: 24px;
            height: 24px;
        }

        /* 상단 타이틀 바 */
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 20px;
        }

        .main-header-title h2 {
            font-size: 26px;
            font-weight: 800;
            margin: 0;
            color: #0f172a;
            letter-spacing: -0.5px;
        }

        .main-header-title p {
            font-size: 13px;
            color: #64748b;
            margin: 6px 0 0 0;
        }

        .header-profile-wrap {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            padding: 8px 16px;
            border-radius: 12px;
        }

        .user-profile {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .user-name {
            font-size: 13px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }

        .user-role {
            font-size: 10px;
            color: #64748b;
            margin: 0;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 6px 12px;
            background: rgba(239, 68, 68, 0.06);
            border: 1px solid rgba(239, 68, 68, 0.15);
            color: #ef4444;
            font-size: 12px;
            font-weight: 700;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.25s ease;
        }

        .btn-logout:hover {
            background: #ef4444;
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.15);
        }

        /* 상세 검색 조건 영역 (라이트모드 리스타일링) */
        .board-controls {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 24px;
            margin-bottom: 30px;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.015);
        }

        .filter-form {
            display: flex;
            flex-direction: column;
            gap: 16px;
        }

        .filter-row {
            display: flex;
            align-items: center;
            gap: 15px;
            flex-wrap: wrap;
        }

        .filter-label {
            font-size: 13px;
            font-weight: 700;
            color: #475569;
            min-width: 60px;
        }

        .filter-inputs {
            display: flex;
            align-items: center;
            gap: 10px;
            flex-wrap: wrap;
            flex: 1;
        }

        /* 라이트모드 폼 컨트롤 */
        .select-control, .date-control, .text-control {
            background: #ffffff;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            color: #0f172a;
            padding: 10px 14px;
            font-size: 14px;
            outline: none;
            font-family: inherit;
            box-sizing: border-box;
            transition: all 0.25s ease;
        }

        .select-control:focus, .date-control:focus, .text-control:focus {
            border-color: #0284c7;
            box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.12);
        }

        .date-control {
            width: 150px;
            cursor: pointer;
        }

        .select-control {
            cursor: pointer;
            min-width: 120px;
        }

        .text-control {
            flex: 1;
            min-width: 200px;
        }

        .filter-btn-group {
            display: flex;
            gap: 10px;
            justify-content: flex-end;
            margin-top: 5px;
            flex-wrap: wrap;
        }

        /* 버튼 기본색 적용 */
        .btn-filter-search {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #0284c7;
            border: none;
            color: #ffffff;
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 800;
            font-size: 14px;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(2, 132, 199, 0.15);
            transition: all 0.25s ease;
        }

        .btn-filter-search:hover {
            background: #0369a1;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(2, 132, 199, 0.25);
        }

        .btn-filter-reset {
            background: #f1f5f9;
            border: 1px solid #cbd5e1;
            color: #334155;
            padding: 10px 20px;
            border-radius: 10px;
            font-weight: 700;
            font-size: 14px;
            text-decoration: none;
            text-align: center;
            cursor: pointer;
            transition: all 0.25s ease;
        }

        .btn-filter-reset:hover {
            background: #e2e8f0;
            color: #0f172a;
        }

        /* 작성/등록 버튼 */
        .btn-write {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            background: #16a34a;
            border: none;
            color: #ffffff;
            padding: 10px 24px;
            border-radius: 10px;
            font-weight: 800;
            font-size: 14px;
            text-decoration: none;
            cursor: pointer;
            box-shadow: 0 4px 12px rgba(22, 163, 74, 0.15);
            transition: all 0.25s ease;
        }

        .btn-write:hover {
            background: #15803d;
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(22, 163, 74, 0.25);
        }

        /* 테이블 카드 컨테이너 */
        .table-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 28px;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.015);
            margin-bottom: 30px;
        }

        .table-container {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            white-space: nowrap;
        }

        th {
            padding: 16px;
            color: #64748b;
            font-weight: 700;
            border-bottom: 1.5px solid #e2e8f0;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: left;
            background-color: #f8fafc;
        }

        td {
            padding: 16px;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
            vertical-align: middle;
        }

        tr:hover td {
            background: #f8fafc;
        }

        /* 배지 스타일 (라이트 파스텔) */
        .badge-pinned {
            background: #fee2e2;
            color: #dc2626;
            border: 1px solid #fecaca;
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: bold;
        }

        .badge-status {
            padding: 4px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: bold;
        }

        .status-pending {
            background: #ffedd5;
            color: #ea580c;
            border: 1px solid #fed7aa;
        }

        .status-complete {
            background: #dcfce7;
            color: #16a34a;
            border: 1px solid #bbf7d0;
        }

        .badge-type {
            background: #e0f2fe;
            color: #0369a1;
            border: 1px solid #bae6fd;
            padding: 2px 6px;
            border-radius: 4px;
            font-size: 11px;
        }

        /* 액션 링크 및 버튼 */
        .action-links {
            display: flex;
            gap: 10px;
        }

        .btn-action-edit {
            color: #0284c7;
            text-decoration: none;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-action-edit:hover {
            color: #0369a1;
            text-decoration: underline;
        }

        .btn-action-del {
            color: #ef4444;
            background: none;
            border: none;
            font-weight: 700;
            cursor: pointer;
            padding: 0;
            font-family: inherit;
            font-size: inherit;
        }

        .btn-action-del:hover {
            text-decoration: underline;
        }

        /* 페이지네이션 */
        .pagination-container {
            display: flex;
            justify-content: center;
            align-items: center;
            gap: 8px;
            margin-top: 20px;
        }

        .page-link {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            color: #475569;
            text-decoration: none;
            font-weight: bold;
            font-size: 14px;
            transition: all 0.25s ease;
        }

        .page-link:hover {
            border-color: #0284c7;
            color: #0284c7;
        }

        .page-link.active {
            background: #0284c7;
            color: #ffffff;
            border-color: #0284c7;
            box-shadow: 0 2px 6px rgba(2, 132, 199, 0.2);
        }

        /* 모바일 네비게이션용 백드롭 */
        .sidebar-backdrop {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.4);
            z-index: 98;
        }

        /* 3. 모바일 반응형 미디어 쿼리 */
        @media (max-width: 992px) {
            .console-sidebar {
                transform: translateX(-100%);
            }
            
            .console-sidebar.open {
                transform: translateX(0);
                box-shadow: 10px 0 35px rgba(15, 23, 42, 0.1);
            }
            
            .console-main {
                margin-left: 0;
                padding: 30px 20px;
            }
            
            .mobile-header {
                display: flex;
            }
            
            .main-header {
                display: none;
            }

            .sidebar-backdrop.open {
                display: block;
            }
        }

        @media (max-width: 768px) {
            .filter-row {
                flex-direction: column;
                align-items: stretch;
            }

            .filter-inputs {
                flex-direction: column;
                align-items: stretch;
            }

            .date-control, .select-control, .text-control {
                width: 100%;
            }

            .filter-btn-group {
                flex-direction: column;
                align-items: stretch;
            }

            .btn-filter-search, .btn-filter-reset, .btn-write {
                width: 100%;
                justify-content: center;
            }
        }
    </style>
</head>
<body>
    <!-- 모바일 전용 헤더 -->
    <div class="mobile-header">
        <div style="display: flex; align-items: center; gap: 10px;">
            <button class="mobile-menu-btn" id="btnToggleMenu" aria-label="메뉴 열기">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <img src="/images/logo.webp" alt="물고기자리" style="height: 28px; width: auto; filter: none;">
        </div>
        <span style="color: #0284c7; font-size: 11px; font-weight: bold; border: 1px solid rgba(2,132,199,0.3); padding: 1px 4px; border-radius: 4px; background: rgba(2,132,199,0.05);">console</span>
    </div>

    <!-- 모바일 사이드바 백드롭 -->
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <div class="dashboard-layout">
        <!-- 좌측 고정 사이드바 -->
        <div class="console-sidebar" id="consoleSidebar">
            <div class="sidebar-logo">
                <img src="/images/logo.webp" alt="물고기자리 로고">
                <span>console</span>
            </div>
            
            <div class="sidebar-menu">
                <!-- 1. 대쉬보드 -->
                <a href="/console/dashboard" class="menu-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="9"></rect>
                        <rect x="14" y="3" width="7" height="5"></rect>
                        <rect x="14" y="12" width="7" height="9"></rect>
                        <rect x="3" y="16" width="7" height="5"></rect>
                    </svg>
                    <span>대쉬보드</span>
                </a>

                <!-- 3. 게시판 관리 (서브메뉴 분리) -->
                <div class="menu-group" style="display: flex; flex-direction: column; gap: 4px; margin-top: 10px;">
                    <div class="menu-group-title" style="padding: 5px 20px; font-size: 11px; font-weight: bold; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;">게시판 관리</div>
                    <a href="/console/board/notice" class="menu-item sub-item <%= (typeof activeMenu !== 'undefined' && activeMenu === 'board_notice') ? 'active' : '' %>">
                        <span>- 공지사항 관리</span>
                    </a>
                    <a href="/console/board/faq" class="menu-item sub-item <%= (typeof activeMenu !== 'undefined' && activeMenu === 'board_faq') ? 'active' : '' %>">
                        <span>- FAQ 관리</span>
                    </a>
                    <a href="/console/board/voice" class="menu-item sub-item <%= (typeof activeMenu !== 'undefined' && activeMenu === 'board_voice') ? 'active' : '' %>">
                        <span>- 고객의 소리 관리</span>
                    </a>
                    <a href="/console/board/inquiry" class="menu-item sub-item <%= (typeof activeMenu !== 'undefined' && activeMenu === 'board_inquiry') ? 'active' : '' %>">
                        <span>- 문의게시판 관리</span>
                    </a>
                </div>

                <!-- 4. 메뉴(음식) 관리 -->
                <a class="menu-item" onclick="alert('준비 중인 기능입니다.')" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                        <path d="M2 12h20"></path>
                    </svg>
                    <span>메뉴(음식) 관리</span>
                </a>

                <!-- 5. 팝업관리 -->
                <a class="menu-item" onclick="alert('준비 중인 기능입니다.')" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="3" x2="9" y2="21"></line>
                        <line x1="17" y1="9" x2="21" y2="9"></line>
                        <line x1="17" y1="15" x2="21" y2="15"></line>
                    </svg>
                    <span>팝업관리</span>
                </a>
            </div>
        </div>

        <!-- 우측 메인 콘텐츠 영역 -->
        <div class="console-main">
            <!-- 메인 헤더 요약 정보 -->
            <% 
                const categoryLabels = {
                    'notice': '공지사항 관리',
                    'faq': '자주 묻는 질문(FAQ) 관리',
                    'voice': '고객의 소리 관리',
                    'inquiry': '문의게시판 관리'
                };
                const currentLabel = categoryLabels[currentCategory] || '게시판 관리';
            %>
            <div class="main-header">
                <div class="main-header-title">
                    <h2><%= currentLabel %></h2>
                    <p><%= currentLabel %> 데이터를 기간 및 검색조건 필터링을 통해 상세 조회하고 관리합니다.</p>
                </div>
                
                <div style="display: flex; align-items: center; gap: 20px;">
                    <div class="header-profile-wrap">
                        <div class="user-profile">
                            <span class="user-name"><%= adminUser.name %> 님</span>
                            <span class="user-role">최고관리자 (ID: <%= adminUser.username %>)</span>
                        </div>
                        <a href="/console/logout" class="btn-logout">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                <polyline points="16 17 21 12 16 7"></polyline>
                                <line x1="21" y1="12" x2="9" y2="12"></line>
                            </svg>
                            <span>로그아웃</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- 컨트롤 바 (고도화된 기간/조건 검색 필터) -->
            <div class="board-controls">
                <form action="/console/board/<%= currentCategory %>" method="GET" class="filter-form">
                    <!-- 1. 기간 설정 필터 -->
                    <div class="filter-row">
                        <div class="filter-label">조회 기간</div>
                        <div class="filter-inputs">
                            <input type="date" name="start_date" class="date-control" value="<%= startDate %>">
                            <span style="color: #cbd5e1;">~</span>
                            <input type="date" name="end_date" class="date-control" value="<%= endDate %>">
                        </div>
                    </div>

                    <!-- 2. 검색 범위 및 검색어 필터 -->
                    <div class="filter-row">
                        <div class="filter-label">검색 조건</div>
                        <div class="filter-inputs">
                            <select name="search_type" class="select-control">
                                <option value="all" <%= searchType === 'all' ? 'selected' : '' %>>통합검색</option>
                                <option value="title" <%= searchType === 'title' ? 'selected' : '' %>><%= currentCategory === 'faq' ? '질문' : '제목' %></option>
                                <option value="content" <%= searchType === 'content' ? 'selected' : '' %>><%= currentCategory === 'faq' ? '답변' : '내용' %></option>
                                <% if (currentCategory !== 'faq') { %>
                                    <option value="author" <%= searchType === 'author' ? 'selected' : '' %>>작성자</option>
                                <% } %>
                            </select>
                            <input type="text" name="search" class="text-control" placeholder="검색어를 입력하세요..." value="<%= search %>">
                        </div>
                    </div>

                    <!-- 3. 필터 제어 버튼 바 -->
                    <div class="filter-btn-group">
                        <a href="/console/board/<%= currentCategory %>" class="btn-filter-reset">검색 초기화</a>
                        <button type="submit" class="btn-filter-search">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: -2px;">
                                <circle cx="11" cy="11" r="8"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                            <span>검색 실행</span>
                        </button>
                        
                        <!-- 공지사항(notice) 및 FAQ(faq) 카테고리만 관리자가 신규 등록 글쓰기가 가능함 -->
                        <% if (currentCategory === 'notice' || currentCategory === 'faq') { %>
                            <a href="/console/board/write?category=<%= currentCategory %>" class="btn-write">
                                <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="margin-bottom: -2px;">
                                    <line x1="12" y1="5" x2="12" y2="19"></line>
                                    <line x1="5" y1="12" x2="19" y2="12"></line>
                                </svg>
                                <span><%= currentCategory === 'notice' ? '공지 등록' : 'FAQ 등록' %></span>
                            </a>
                        <% } %>
                    </div>
                </form>
            </div>

            <!-- 데이터 리스트 테이블 -->
            <div class="table-card">
                <div class="table-container">
                    <% if (list && list.length > 0) { %>
                        <table>
                            <thead>
                                <tr>
                                    <th style="width: 70px;">번호</th>
                                    
                                    <% if (currentCategory === 'notice') { %>
                                        <th>제목</th>
                                        <th style="width: 120px;">구분</th>
                                        <th style="width: 150px;">등록일</th>
                                        <th style="width: 100px;">조회수</th>
                                    <% } else if (currentCategory === 'faq') { %>
                                        <th>질문 (제목)</th>
                                        <th>답변 요약</th>
                                        <th style="width: 150px;">등록일</th>
                                    <% } else if (currentCategory === 'voice') { %>
                                        <th>불편/불만 내용</th>
                                        <th style="width: 120px;">작성자</th>
                                        <th style="width: 150px;">연락처</th>
                                        <th style="width: 150px;">접수일</th>
                                        <th style="width: 120px;">처리상태</th>
                                    <% } else if (currentCategory === 'inquiry') { %>
                                        <th style="width: 150px;">문의분류</th>
                                        <th>문의내역 제목</th>
                                        <th style="width: 120px;">작성자</th>
                                        <th style="width: 150px;">연락처 / 이메일</th>
                                        <th style="width: 150px;">접수일</th>
                                        <th style="width: 120px;">처리상태</th>
                                    <% } %>
                                    
                                    <th style="width: 120px; text-align: center;">관리</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% list.forEach((item, index) => { %>
                                    <tr id="row-<%= item.id %>">
                                        <!-- 번호 계산 -->
                                        <td><%= totalItems - ((currentPage - 1) * 10 + index) %></td>
                                        
                                        <% if (currentCategory === 'notice') { %>
                                            <!-- 공지사항 렌더링 -->
                                            <td style="white-space: normal; word-break: break-all;">
                                                <a href="/console/board/edit/<%= item.id %>" class="btn-action-edit" style="color: inherit; text-decoration: none;">
                                                    <%= item.title %>
                                                </a>
                                            </td>
                                            <td>
                                                <% if (item.is_pinned === 1) { %>
                                                    <span class="badge-pinned">필독고정</span>
                                                <% } else { %>
                                                    <span style="color: #94a3b8;">일반</span>
                                                <% } %>
                                            </td>
                                            <td><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                            <td><%= item.views %></td>
                                        <% } else if (currentCategory === 'faq') { %>
                                            <!-- FAQ 렌더링 -->
                                            <td style="white-space: normal; word-break: break-all;">
                                                <a href="/console/board/edit/<%= item.id %>" class="btn-action-edit" style="color: inherit; text-decoration: none;">
                                                    Q. <%= item.title %>
                                                </a>
                                            </td>
                                            <td style="white-space: normal; word-break: break-all; color: #64748b;">
                                                <%= item.content.length > 50 ? item.content.substring(0, 50) + '...' : item.content %>
                                            </td>
                                            <td><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                        <% } else if (currentCategory === 'voice') { %>
                                            <!-- 고객의소리 렌더링 -->
                                            <td style="white-space: normal; word-break: break-all;">
                                                <a href="/console/board/edit/<%= item.id %>" class="btn-action-edit" style="color: inherit; text-decoration: none;">
                                                    <%= item.content.length > 40 ? item.content.substring(0, 40) + '...' : item.content %>
                                                </a>
                                            </td>
                                            <td><%= item.author_name %></td>
                                            <td><%= item.author_phone %></td>
                                            <td><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                            <td>
                                                <span class="badge-status <%= item.status === 'complete' ? 'status-complete' : 'status-pending' %>">
                                                    <%= item.status === 'complete' ? '답변완료' : '답변대기' %>
                                                </span>
                                            </td>
                                        <% } else if (currentCategory === 'inquiry') { %>
                                            <!-- 문의게시판 렌더링 -->
                                            <td>
                                                <% 
                                                    const inquiryTypeMap = {
                                                        'franchise': '신규 가맹/창업',
                                                        'location': '매장 개설/상권 분석',
                                                        'alliance': '비즈니스 제휴/납품',
                                                        'other': '기타 문의사항'
                                                    };
                                                %>
                                                <span class="badge-type"><%= inquiryTypeMap[item.inquiry_type] || '기타 문의' %></span>
                                            </td>
                                            <td style="white-space: normal; word-break: break-all;">
                                                <a href="/console/board/edit/<%= item.id %>" class="btn-action-edit" style="color: inherit; text-decoration: none;">
                                                    <%= item.title %>
                                                </a>
                                            </td>
                                            <td><%= item.author_name %></td>
                                            <td>
                                                <div><%= item.author_phone %></div>
                                                <div style="font-size: 11px; color: #64748b; margin-top: 2px;"><%= item.author_email || '-' %></div>
                                            </td>
                                            <td><%= new Date(item.created_at).toLocaleDateString('ko-KR') %></td>
                                            <td>
                                                <span class="badge-status <%= item.status === 'complete' ? 'status-complete' : 'status-pending' %>">
                                                    <%= item.status === 'complete' ? '답변완료' : '답변대기' %>
                                                </span>
                                            </td>
                                        <% } %>
                                        
                                        <!-- 공통 관리 액션 (수정/답변 및 삭제) -->
                                        <td style="text-align: center;">
                                            <div class="action-links" style="justify-content: center;">
                                                <a href="/console/board/edit/<%= item.id %>" class="btn-action-edit">
                                                    <%= (currentCategory === 'voice' || currentCategory === 'inquiry') ? '답변' : '수정' %>
                                                </a>
                                                <span style="color: #e2e8f0;">|</span>
                                                <button type="button" class="btn-action-del" onclick="deleteItem('<%= item.id %>')">삭제</button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div style="text-align: center; padding: 50px; color: #64748b;">
                            접수되거나 검색 결과에 매칭되는 데이터 내역이 존재하지 않습니다.
                        </div>
                    <% } %>
                </div>

                <!-- 페이지네이션 (검색 조건 파라미터 연계) -->
                <% if (totalPages > 1) { %>
                    <div class="pagination-container">
                        <% 
                            const pagelink = `/console/board/${currentCategory}?search=${search}&search_type=${searchType}&start_date=${startDate}&end_date=${endDate}`;
                        %>
                        <% if (currentPage > 1) { %>
                            <a href="<%= pagelink %>&page=<%= currentPage - 1 %>" class="page-link">&lt;</a>
                        <% } %>
                        
                        <% for (let i = 1; i <= totalPages; i++) { %>
                            <a href="<%= pagelink %>&page=<%= i %>" class="page-link <%= currentPage === i ? 'active' : '' %>"><%= i %></a>
                        <% } %>
                        
                        <% if (currentPage < totalPages) { %>
                            <a href="<%= pagelink %>&page=<%= currentPage + 1 %>" class="page-link">&gt;</a>
                        <% } %>
                    </div>
                <% } %>
            </div>
        </div>
    </div>

    <script>
        // 비동기 글 삭제 처리
        async function deleteItem(id) {
            if (!confirm('정말로 이 항목을 영구 삭제하시겠습니까?')) {
                return;
            }

            try {
                const response = await fetch(`/api/board/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();
                if (data.success) {
                    alert(data.message || '삭제되었습니다.');
                    // DOM에서 즉시 해당 줄 제거
                    const tr = document.getElementById(`row-${id}`);
                    if (tr) {
                        tr.remove();
                    } else {
                        location.reload();
                    }
                } else {
                    alert(data.message || '삭제에 실패했습니다.');
                }
            } catch (err) {
                console.error('Delete error:', err);
                alert('서버 통신 에러가 발생하여 삭제에 실패했습니다.');
            }
        }

        // 모바일 사이드바 토글 스크립트
        const btnToggleMenu = document.getElementById('btnToggleMenu');
        const consoleSidebar = document.getElementById('consoleSidebar');
        const sidebarBackdrop = document.getElementById('sidebarBackdrop');

        if (btnToggleMenu && consoleSidebar && sidebarBackdrop) {
            const toggleSidebar = () => {
                consoleSidebar.classList.toggle('open');
                sidebarBackdrop.classList.toggle('open');
            };

            btnToggleMenu.addEventListener('click', toggleSidebar);
            sidebarBackdrop.addEventListener('click', toggleSidebar);
        }
    </script>
</body>
</html>
