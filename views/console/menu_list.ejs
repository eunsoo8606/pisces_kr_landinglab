<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <link rel="shortcut icon" href="/favicon.ico?v=2" type="image/x-icon">
    <link rel="icon" href="/favicon.webp?v=2" type="image/png">
    <style>
        /* 프리미엄 라이트 테마 */
        body {
            background-color: #f8fafc;
            color: #334155;
            font-family: 'Pretendard', -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
            min-height: 100vh;
            margin: 0;
            overflow-x: hidden;
        }

        .dashboard-layout {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        /* 1. 좌측 고정 사이드바 */
        .console-sidebar {
            width: 270px;
            background: #ffffff;
            border-right: 1px solid #e2e8f0;
            display: flex;
            flex-direction: column;
            position: fixed;
            height: 100vh;
            left: 0;
            top: 0;
            z-index: 100;
            box-sizing: border-box;
            box-shadow: 4px 0 20px rgba(15, 23, 42, 0.02);
            transition: transform 0.3s ease;
        }

        .sidebar-logo {
            padding: 28px 24px;
            border-bottom: 1px solid #f1f5f9;
            display: flex;
            align-items: center;
            justify-content: flex-start;
            gap: 10px;
        }

        .sidebar-logo img {
            height: 38px;
            width: auto;
        }

        .sidebar-logo span {
            color: #0284c7;
            font-size: 11px;
            font-weight: 700;
            text-transform: uppercase;
            border: 1px solid rgba(2, 132, 199, 0.25);
            padding: 2px 6px;
            border-radius: 4px;
            background-color: rgba(2, 132, 199, 0.05);
            letter-spacing: 0.5px;
        }

        .sidebar-menu {
            flex: 1;
            padding: 30px 16px;
            display: flex;
            flex-direction: column;
            gap: 8px;
            overflow-y: auto;
        }

        .menu-item {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 12px 18px;
            color: #475569;
            text-decoration: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 700;
            transition: all 0.25s ease;
            cursor: pointer;
            border: 1px solid transparent;
            box-sizing: border-box;
        }

        .menu-item svg {
            width: 18px;
            height: 18px;
            flex-shrink: 0;
            color: #64748b;
            transition: transform 0.2s ease;
        }

        .menu-item:hover {
            color: #0284c7;
            background: #f8fafc;
        }

        .menu-item:hover svg {
            transform: translateX(2px);
            color: #0284c7;
        }

        .menu-item.active {
            color: #0284c7;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        .menu-item.active svg {
            color: #0284c7;
        }

        .menu-item.sub-item {
            font-size: 13px;
            padding: 8px 18px 8px 30px;
            color: #64748b;
        }

        .menu-item.sub-item.active {
            color: #0369a1;
            background: rgba(2, 132, 199, 0.08);
            font-weight: 800;
        }

        /* 2. 우측 메인 콘텐츠 영역 */
        .console-main {
            margin-left: 270px;
            flex: 1;
            padding: 40px 50px;
            box-sizing: border-box;
            min-width: 0;
            transition: margin-left 0.3s ease;
        }

        /* 모바일 햄버거 헤더 */
        .mobile-header {
            display: none;
            justify-content: space-between;
            align-items: center;
            background: #ffffff;
            padding: 15px 20px;
            border-bottom: 1px solid #e2e8f0;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .mobile-menu-btn {
            background: none;
            border: none;
            color: #0f172a;
            cursor: pointer;
            padding: 5px;
        }

        .mobile-menu-btn svg {
            width: 24px;
            height: 24px;
        }

        /* 상단 타이틀 바 */
        .main-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            border-bottom: 1px solid #e2e8f0;
            padding-bottom: 20px;
        }

        .main-header-title h2 {
            font-size: 26px;
            font-weight: 800;
            margin: 0;
            color: #0f172a;
            letter-spacing: -0.5px;
        }

        .main-header-title p {
            font-size: 13px;
            color: #64748b;
            margin: 6px 0 0 0;
        }

        .header-profile-wrap {
            display: flex;
            align-items: center;
            gap: 15px;
            background: #ffffff;
            border: 1px solid #e2e8f0;
            padding: 8px 16px;
            border-radius: 12px;
        }

        .user-profile {
            display: flex;
            flex-direction: column;
            gap: 2px;
        }

        .user-name {
            font-size: 13px;
            font-weight: 800;
            color: #0f172a;
            margin: 0;
        }

        .user-role {
            font-size: 10px;
            color: #64748b;
            margin: 0;
        }

        .btn-logout {
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 6px;
            padding: 6px 12px;
            background: rgba(239, 68, 68, 0.06);
            border: 1px solid rgba(239, 68, 68, 0.15);
            color: #ef4444;
            font-size: 12px;
            font-weight: 700;
            border-radius: 8px;
            text-decoration: none;
            transition: all 0.25s ease;
        }

        .btn-logout:hover {
            background: #ef4444;
            color: #ffffff;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.15);
        }

        /* 상세 검색 조건 영역 */
        .board-controls {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            padding: 24px;
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
            margin-bottom: 24px;
        }

        .filter-row {
            display: flex;
            align-items: center;
            gap: 20px;
            padding-bottom: 16px;
            border-bottom: 1px solid #f1f5f9;
            margin-bottom: 16px;
        }

        .filter-row:last-of-type {
            border-bottom: none;
            padding-bottom: 0;
            margin-bottom: 0;
        }

        .filter-label {
            width: 100px;
            font-size: 13px;
            font-weight: bold;
            color: #475569;
        }

        .filter-inputs {
            display: flex;
            align-items: center;
            gap: 10px;
            flex: 1;
            flex-wrap: wrap;
        }

        .select-control {
            padding: 10px 14px;
            border: 1px solid #cbd5e1;
            border-radius: 10px;
            font-size: 13px;
            background-color: #ffffff;
            color: #334155;
            outline: none;
            transition: all 0.2s ease;
        }

        .select-control:focus {
            border-color: #0284c7;
            box-shadow: 0 0 0 3px rgba(2, 132, 199, 0.1);
        }

        .filter-btn-group {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 10px;
            margin-top: 15px;
        }

        .btn-filter-reset {
            padding: 10px 20px;
            background: #f1f5f9;
            border: 1px solid #cbd5e1;
            color: #475569;
            font-size: 13px;
            font-weight: 700;
            border-radius: 10px;
            text-decoration: none;
            transition: all 0.2s ease;
        }

        .btn-filter-reset:hover {
            background: #e2e8f0;
        }

        .btn-filter-search {
            padding: 10px 24px;
            background: #0284c7;
            border: 1px solid #0284c7;
            color: #ffffff;
            font-size: 13px;
            font-weight: 700;
            border-radius: 10px;
            cursor: pointer;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.25s ease;
        }

        .btn-filter-search:hover {
            background: #0369a1;
            border-color: #0369a1;
            box-shadow: 0 4px 12px rgba(2, 132, 199, 0.15);
        }

        .btn-write {
            padding: 10px 24px;
            background: #0f172a;
            border: 1px solid #0f172a;
            color: #ffffff;
            font-size: 13px;
            font-weight: 700;
            border-radius: 10px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            transition: all 0.25s ease;
        }

        .btn-write:hover {
            background: #1e293b;
            border-color: #1e293b;
            box-shadow: 0 4px 12px rgba(15, 23, 42, 0.15);
        }

        /* 테이블 카드 레이아웃 */
        .table-card {
            background: #ffffff;
            border: 1px solid #e2e8f0;
            border-radius: 16px;
            box-shadow: 0 4px 20px rgba(15, 23, 42, 0.02);
            overflow: hidden;
            margin-bottom: 30px;
        }

        .table-container {
            overflow-x: auto;
            -webkit-overflow-scrolling: touch;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            font-size: 14px;
            white-space: nowrap;
        }

        th {
            padding: 16px;
            color: #64748b;
            font-weight: 700;
            border-bottom: 1.5px solid #e2e8f0;
            font-size: 11px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: left;
            background-color: #f8fafc;
        }

        td {
            padding: 16px;
            border-bottom: 1px solid #f1f5f9;
            color: #334155;
            vertical-align: middle;
        }

        tr:hover td {
            background: #f8fafc;
        }

        /* 썸네일 이미지 미리보기 */
        .food-thumb {
            width: 50px;
            height: 50px;
            border-radius: 8px;
            object-fit: cover;
            border: 1px solid #cbd5e1;
        }

        /* 배지 스타일 */
        .badge-badge {
            background: #fee2e2;
            color: #dc2626;
            border: 1px solid #fecaca;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: bold;
            text-transform: uppercase;
        }
        
        .badge-category {
            background: #e0f2fe;
            color: #0369a1;
            border: 1px solid #bae6fd;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 11px;
        }

        .badge-main {
            background: #dcfce7;
            color: #16a34a;
            border: 1px solid #bbf7d0;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 11px;
            font-weight: bold;
        }

        .badge-sub {
            background: #f1f5f9;
            color: #64748b;
            border: 1px solid #cbd5e1;
            padding: 3px 8px;
            border-radius: 4px;
            font-size: 11px;
        }

        /* 액션 링크 및 버튼 */
        .action-links {
            display: flex;
            gap: 10px;
        }

        .btn-action-edit {
            color: #0284c7;
            text-decoration: none;
            font-weight: 700;
            cursor: pointer;
        }

        .btn-action-edit:hover {
            color: #0369a1;
            text-decoration: underline;
        }

        .btn-action-del {
            color: #ef4444;
            background: none;
            border: none;
            font-weight: 700;
            cursor: pointer;
            padding: 0;
            font-family: inherit;
            font-size: inherit;
        }

        .btn-action-del:hover {
            text-decoration: underline;
        }

        /* 모바일 네비게이션용 백드롭 */
        .sidebar-backdrop {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100vw;
            height: 100vh;
            background: rgba(0, 0, 0, 0.4);
            z-index: 98;
        }

        /* 모바일 반응형 미디어 쿼리 */
        @media (max-width: 992px) {
            .console-sidebar {
                transform: translateX(-100%);
            }
            
            .console-sidebar.open {
                transform: translateX(0);
                box-shadow: 10px 0 35px rgba(15, 23, 42, 0.1);
            }
            
            .console-main {
                margin-left: 0;
                padding: 30px 20px;
            }
            
            .mobile-header {
                display: flex;
            }
            
            .main-header {
                display: none;
            }

            .sidebar-backdrop.open {
                display: block;
            }
        }
    </style>
</head>
<body>
    <!-- 모바일 전용 헤더 -->
    <div class="mobile-header">
        <div style="display: flex; align-items: center; gap: 10px;">
            <button class="mobile-menu-btn" id="btnToggleMenu" aria-label="메뉴 열기">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="3" y1="12" x2="21" y2="12"></line>
                    <line x1="3" y1="6" x2="21" y2="6"></line>
                    <line x1="3" y1="18" x2="21" y2="18"></line>
                </svg>
            </button>
            <img src="/images/logo.webp" alt="물고기자리" style="height: 28px; width: auto;">
        </div>
        <span style="color: #0284c7; font-size: 11px; font-weight: bold; border: 1px solid rgba(2,132,199,0.3); padding: 1px 4px; border-radius: 4px; background: rgba(2,132,199,0.05);">console</span>
    </div>

    <!-- 모바일 사이드바 백드롭 -->
    <div class="sidebar-backdrop" id="sidebarBackdrop"></div>

    <div class="dashboard-layout">
        <!-- 좌측 고정 사이드바 -->
        <div class="console-sidebar" id="consoleSidebar">
            <div class="sidebar-logo">
                <img src="/images/logo.webp" alt="물고기자리 로고">
                <span>console</span>
            </div>
            
            <div class="sidebar-menu">
                <!-- 1. 대쉬보드 -->
                <a href="/console/dashboard" class="menu-item">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="7" height="9"></rect>
                        <rect x="14" y="3" width="7" height="5"></rect>
                        <rect x="14" y="12" width="7" height="9"></rect>
                        <rect x="3" y="16" width="7" height="5"></rect>
                    </svg>
                    <span>대쉬보드</span>
                </a>

                <!-- 3. 게시판 관리 -->
                <div class="menu-group" style="display: flex; flex-direction: column; gap: 4px; margin-top: 10px;">
                    <div class="menu-group-title" style="padding: 5px 20px; font-size: 11px; font-weight: bold; color: #94a3b8; text-transform: uppercase; letter-spacing: 1px;">게시판 관리</div>
                    <a href="/console/board/notice" class="menu-item sub-item">
                        <span>- 공지사항 관리</span>
                    </a>
                    <a href="/console/board/faq" class="menu-item sub-item">
                        <span>- FAQ 관리</span>
                    </a>
                    <a href="/console/board/voice" class="menu-item sub-item">
                        <span>- 고객의 소리 관리</span>
                    </a>
                    <a href="/console/board/inquiry" class="menu-item sub-item">
                        <span>- 문의게시판 관리</span>
                    </a>
                </div>

                <!-- 4. 메뉴(음식) 관리 -->
                <a href="/console/menu" class="menu-item active" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="10"></circle>
                        <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                        <path d="M2 12h20"></path>
                    </svg>
                    <span>메뉴(음식) 관리</span>
                </a>

                <!-- 5. 팝업관리 -->
                <a href="/console/popup" class="menu-item <%= (typeof activeMenu !== 'undefined' && activeMenu === 'popup') ? 'active' : '' %>" style="margin-top: 10px;">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="3" y="3" width="18" height="18" rx="2" ry="2"></rect>
                        <line x1="9" y1="3" x2="9" y2="21"></line>
                        <line x1="17" y1="9" x2="21" y2="9"></line>
                        <line x1="17" y1="15" x2="21" y2="15"></line>
                    </svg>
                    <span>팝업관리</span>
                </a>
            </div>
        </div>

        <!-- 우측 메인 콘텐츠 영역 -->
        <div class="console-main">
            <!-- 메인 헤더 -->
            <div class="main-header">
                <div class="main-header-title">
                    <h2>메뉴(음식) 관리</h2>
                    <p>메인 홈페이지 및 메뉴소개 페이지에 노출될 음식 메뉴 리스트를 조회하고 수정합니다.</p>
                </div>
                
                <div style="display: flex; align-items: center; gap: 20px;">
                    <div class="header-profile-wrap">
                        <div class="user-profile">
                            <span class="user-name"><%= adminUser.name %> 님</span>
                            <span class="user-role">최고관리자 (ID: <%= adminUser.username %>)</span>
                        </div>
                        <a href="/console/logout" class="btn-logout">
                            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"></path>
                                <polyline points="16 17 21 12 16 7"></polyline>
                                <line x1="21" y1="12" x2="9" y2="12"></line>
                            </svg>
                            <span>로그아웃</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- 컨트롤 바 -->
            <div class="board-controls">
                <form action="/console/menu" method="GET" class="filter-form">
                    <div class="filter-row">
                        <div class="filter-label">카테고리 분류</div>
                        <div class="filter-inputs">
                            <select name="category" class="select-control">
                                <option value="">전체 카테고리</option>
                                <% Object.keys(categoryLabels).forEach(key => { %>
                                    <option value="<%= key %>" <%= categoryFilter === key ? 'selected' : '' %>><%= categoryLabels[key] %></option>
                                <% }) %>
                            </select>
                        </div>
                    </div>

                    <div class="filter-row">
                        <div class="filter-label">메뉴명 검색</div>
                        <div class="filter-inputs">
                            <input type="text" name="search" class="select-control" style="width: 240px;" placeholder="검색할 메뉴명 입력..." value="<%= typeof searchVal !== 'undefined' ? searchVal : '' %>">
                        </div>
                    </div>

                    <div class="filter-btn-group">
                        <a href="/console/menu" class="btn-filter-reset">필터 초기화</a>
                        <button type="submit" class="btn-filter-search">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                <circle cx="11" cy="11" r="8"></circle>
                                <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                            </svg>
                            <span>조회</span>
                        </button>
                        <a href="/console/menu/write" class="btn-write">
                            <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                                <line x1="12" y1="5" x2="12" y2="19"></line>
                                <line x1="5" y1="12" x2="19" y2="12"></line>
                            </svg>
                            <span>메뉴 추가</span>
                        </a>
                    </div>
                </form>
            </div>

            <!-- 데이터 리스트 테이블 -->
            <div class="table-card">
                <div class="table-container">
                    <% if (list && list.length > 0) { %>
                        <table>
                            <thead>
                                <tr>
                                    <th style="width: 70px; text-align: center;">ID</th>
                                    <th style="width: 80px; text-align: center;">이미지</th>
                                    <th style="width: 120px;">카테고리</th>
                                    <th style="width: 100px; text-align: center;">뱃지</th>
                                    <th>메뉴명</th>
                                    <th style="width: 120px;">가격</th>
                                    <th style="width: 100px; text-align: center;">대표메뉴</th>
                                    <th style="width: 80px; text-align: center;">정렬 순서</th>
                                    <th style="width: 120px; text-align: center;">관리</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% list.forEach(item => { %>
                                    <tr id="row-<%= item.id %>">
                                        <td style="text-align: center; color: #94a3b8; font-weight: bold;"><%= item.id %></td>
                                        <td style="text-align: center;">
                                            <img src="<%= item.image_url %>" alt="<%= item.name %>" class="food-thumb" onerror="this.src='/images/logo.webp'">
                                        </td>
                                        <td>
                                            <span class="badge-category"><%= categoryLabels[item.category] || item.category %></span>
                                        </td>
                                        <td style="text-align: center;">
                                            <% if (item.badge) { %>
                                                <span class="badge-badge"><%= item.badge %></span>
                                            <% } else { %>
                                                <span style="color: #cbd5e1;">-</span>
                                            <% } %>
                                        </td>
                                        <td style="font-weight: 700; color: #0f172a;"><%= item.name %></td>
                                        <td style="font-weight: 600; color: #475569;"><%= item.price %></td>
                                        <td style="text-align: center;">
                                            <% if (item.is_main === 1) { %>
                                                <span class="badge-main">대표(Main)</span>
                                            <% } else { %>
                                                <span class="badge-sub">일반</span>
                                            <% } %>
                                        </td>
                                        <td style="text-align: center; font-weight: bold; color: #0284c7;"><%= item.sort_order %></td>
                                        <td style="text-align: center;">
                                            <div class="action-links" style="justify-content: center;">
                                                <a href="/console/menu/edit/<%= item.id %>" class="btn-action-edit">수정</a>
                                                <span style="color: #e2e8f0;">|</span>
                                                <button type="button" class="btn-action-del" onclick="deleteMenu('<%= item.id %>')">삭제</button>
                                            </div>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    <% } else { %>
                        <div style="text-align: center; padding: 50px; color: #64748b;">
                            등록된 메뉴 데이터 내역이 존재하지 않습니다.
                        </div>
                    <% } %>
                </div>
            </div>
        </div>
    </div>

    <script>
        // 비동기 메뉴 삭제 처리
        async function deleteMenu(id) {
            if (!confirm('정말로 이 메뉴를 영구 삭제하시겠습니까?')) {
                return;
            }

            try {
                const response = await fetch(`/api/menu/${id}`, {
                    method: 'DELETE',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                });

                const data = await response.json();
                if (data.success) {
                    alert(data.message || '삭제되었습니다.');
                    // DOM에서 즉시 해당 줄 제거
                    const tr = document.getElementById(`row-${id}`);
                    if (tr) {
                        tr.remove();
                    } else {
                        location.reload();
                    }
                } else {
                    alert(data.message || '삭제에 실패했습니다.');
                }
            } catch (err) {
                console.error('Delete error:', err);
                alert('서버 통신 에러가 발생하여 삭제에 실패했습니다.');
            }
        }

        // 모바일 사이드바 토글 스크립트
        const btnToggleMenu = document.getElementById('btnToggleMenu');
        const consoleSidebar = document.getElementById('consoleSidebar');
        const sidebarBackdrop = document.getElementById('sidebarBackdrop');

        if (btnToggleMenu && consoleSidebar && sidebarBackdrop) {
            const toggleSidebar = () => {
                consoleSidebar.classList.toggle('open');
                sidebarBackdrop.classList.toggle('open');
            };

            btnToggleMenu.addEventListener('click', toggleSidebar);
            sidebarBackdrop.addEventListener('click', toggleSidebar);
        }
    </script>
</body>
</html>
